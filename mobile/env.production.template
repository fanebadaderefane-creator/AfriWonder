# Copier vers .env (local) ou configurer via `eas secret:create --name EXPO_PUBLIC_...`
# Ne jamais committer .env avec des secrets réels.
#
# API unique avec la PWA : même backend FastAPI que frontend/ (proxy ou URL directe).
# Base sans /api final : le client ajoute /api (voir src/api/client.js).
#
# Dev PC (simulateur / même machine) :
# EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
#
# Téléphone sur le même Wi‑Fi que le PC (remplacer par l’IP LAN du PC, ex. ipconfig) :
# EXPO_PUBLIC_API_URL=http://192.168.1.11:8000

# EAS / Expo Push — UUID du projet (expo.dev → Project settings)
EXPO_PUBLIC_EAS_PROJECT_ID=

# Orange Money (production / partenaire)
EXPO_PUBLIC_ORANGE_MONEY_MERCHANT_KEY=
EXPO_PUBLIC_ORANGE_MONEY_CLIENT_ID=
EXPO_PUBLIC_ORANGE_MONEY_CLIENT_SECRET=
EXPO_PUBLIC_ORANGE_MONEY_API_BASE=https://api.orange.com/orange-money-webpay/sen/v1

# Wave
EXPO_PUBLIC_WAVE_API_KEY=
EXPO_PUBLIC_WAVE_BUSINESS_ID=
EXPO_PUBLIC_WAVE_API_BASE=https://api.wave.com
