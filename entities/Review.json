{
  "name": "Review",
  "type": "object",
  "properties": {
    "provider_profile_id": {
      "type": "string",
      "description": "ID du profil prestataire"
    },
    "reviewer_email": {
      "type": "string",
      "description": "Email du client qui laisse l'avis"
    },
    "reviewer_name": {
      "type": "string"
    },
    "rating": {
      "type": "number",
      "description": "Note de 1 à 5"
    },
    "comment": {
      "type": "string"
    },
    "is_flagged": {
      "type": "boolean",
      "default": false,
      "description": "Signalé comme abusif"
    }
  },
  "required": [
    "provider_profile_id",
    "reviewer_email",
    "rating"
  ]
}
