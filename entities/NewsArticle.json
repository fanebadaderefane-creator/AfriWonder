{
  "name": "NewsArticle",
  "type": "object",
  "properties": {
    "author_email": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "politics",
        "economy",
        "culture",
        "sport",
        "technology",
        "health",
        "other"
      ]
    },
    "cover_url": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "is_published": {
      "type": "boolean",
      "default": false
    },
    "is_premium": {
      "type": "boolean",
      "default": false
    },
    "total_views": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "author_email",
    "title",
    "content"
  ]
}
