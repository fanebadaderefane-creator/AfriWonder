{
  "name": "JobApplication",
  "type": "object",
  "properties": {
    "job_id": {
      "type": "string"
    },
    "applicant_email": {
      "type": "string"
    },
    "applicant_name": {
      "type": "string"
    },
    "cover_letter": {
      "type": "string"
    },
    "cv_url": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "reviewed",
        "accepted",
        "rejected"
      ],
      "default": "pending"
    }
  },
  "required": [
    "job_id",
    "applicant_email"
  ]
}
