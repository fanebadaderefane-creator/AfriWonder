# ============================================================
# AfriWonder — Template .env PRODUCTION
# Copier vers backend/.env et remplir toutes les valeurs
# Vérification: cd backend && npm run check:prod-env
# ============================================================

# ========== OBLIGATOIRES (sans elles, l'app ne démarre pas) ==========
NODE_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/afriwonder
JWT_SECRET=GENERER_64_CARACTERES_ALEATOIRES
JWT_REFRESH_SECRET=GENERER_64_CARACTERES_ALEATOIRES
CORS_ORIGIN=https://votre-domaine.com
REDIS_URL=redis://localhost:6379
APP_URL=https://api.votre-domaine.com

# ========== SERVEUR ==========
PORT=3000

# ========== PAIEMENTS (selon contrats signés) ==========
# Orange Money Mali
ORANGE_MONEY_MERCHANT_ID=
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_WEBHOOK_SECRET=OBLIGATOIRE_EN_PROD
ORANGE_MONEY_ENV=production

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Moov Money
MOOV_MONEY_WEBHOOK_SECRET=OBLIGATOIRE_SI_MOOV_ACTIF
MOOV_MONEY_ENV=production

# Wave / MTN (selon providers)
# WAVE_API_KEY=
# MTN_MOBILE_MONEY_API_KEY=

# ========== MONITORING ==========
SENTRY_DSN=https://xxx@sentry.io/yyy
HEALTH_API_KEY=cle_secrete_pour_health_errors
ERROR_WEBHOOK_URL=https://hooks.slack.com/... 

# ========== STOCKAGE (R2 / S3) — vidéos, images, backups ==========
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=afriwonder-prod

# ========== LIVE (Agora) ==========
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ========== NOTIFICATIONS (optionnel) ==========
# SENDGRID_API_KEY=
# FCM_PROJECT_ID=
# FCM_PRIVATE_KEY=
# FCM_CLIENT_EMAIL=

# ========== PLATEFORME ==========
PLATFORM_USER_ID=00000000-0000-0000-0000-000000000000

# Phase 1 Marketplace : abonnements uniquement, 0% commission (true = activé)
# MARKETPLACE_PHASE1_SUBSCRIPTION_ONLY=true

# ========== BACKUPS ==========
BACKUP_DIR=backups
