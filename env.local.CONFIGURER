# BASE44 CONFIGURATION (OBLIGATOIRE)
# Valeurs extraites de votre exemple Base44
VITE_BASE44_APP_ID=697bc0a026fbb0821670a468
VITE_BASE44_APP_BASE_URL=https://app.base44.com/apps/697bc0a026fbb0821670a468
VITE_BASE44_FUNCTIONS_VERSION=v1

# ============================================
# OPTIONNEL - Paiements
# ============================================

# Orange Money Mali - Environnement de Test
# Informations extraites de votre configuration de test
VITE_ORANGE_MERCHANT_ID=7701901162
VITE_REACT_APP_ORANGE_MERCHANT_ID=7701901162
# Note: Pour obtenir la clé marchand (API_KEY), utiliser:
# - MSISDN: 7701901162
# - Agent Code: 102782
# Contactez Orange Money Mali pour obtenir l'API_KEY avec ces informations
VITE_ORANGE_API_KEY=[OBTENIR_VIA_MSISDN_ET_AGENT_CODE]
VITE_REACT_APP_ORANGE_API_KEY=[OBTENIR_VIA_MSISDN_ET_AGENT_CODE]

# Orange Money - Informations supplémentaires (pour référence)
# MSISDN Marchand: 7701901162
# Agent Code: 102782
# PIN: 5324 (ne pas mettre dans .env.local pour sécurité)
# MSISDN Abonné Test: 7701101162
# PIN Abonné: 7936

# Stripe (Paiements par Carte)
