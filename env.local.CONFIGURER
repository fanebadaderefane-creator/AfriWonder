# ============================================
# COMPTES DE TEST (Subscribers) - Pour tester les paiements
# ============================================
# Compte 1: MSISDN 7701101162, PIN 7936, Balance 1 000 000 FCFA
# Compte 2: MSISDN 7701101163, PIN 2028, Balance 1 000 000 FCFA
# Utiliser ces comptes pour tester les paiements dans l'application

# ============================================
# IMPORTANT - Validité du Token
# ============================================
# Le token Orange Money a une validité de 1 heure
# Le backend doit implémenter un refresh automatique

# Stripe (Paiements par Carte)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_votre_cle_publique

# ============================================
# OPTIONNEL - Autres Services
