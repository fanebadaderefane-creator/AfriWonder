      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "preview",
        "EXPO_PUBLIC_BACKEND_URL": "https://afriwonder.onrender.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "777976865742-nl819nbcpn152m9t9pfes4urhefm0i68.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "777976865742-n1ij65icbjucklt3hb6bilpc43gf2rji.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "777976865742-adc2srg5m3omceglol1aqrcogd9rtl7e.apps.googleusercontent.com",
        "EXPO_PUBLIC_FACEBOOK_APP_ID": "1461264728859875",
        "EXPO_PUBLIC_EXPO_ACCOUNT": "abdoulaye_fane",
        "EXPO_PUBLIC_APPLE_SIGN_IN": "on"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_BACKEND_URL": "https://afriwonder.onrender.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "777976865742-nl819nbcpn152m9t9pfes4urhefm0i68.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "777976865742-n1ij65icbjucklt3hb6bilpc43gf2rji.apps.googleusercontent.com",
