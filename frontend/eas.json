        "EXPO_PUBLIC_FACEBOOK_APP_ID": "1461264728859875",
        "EXPO_PUBLIC_EXPO_ACCOUNT": "abdoulaye_fane",
        "EXPO_PUBLIC_APPLE_SIGN_IN": "on"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
