# Fichiers exclus de l’archive (upload léger = moins de ECONNRESET en monorepo).
# Important: avec Git, EAS lit `.easignore` à la racine du dépôt uniquement (expo.fyi/eas-build-archive).
# Ce fichier s’applique quand vous lancez un build via `npm run eas:android:*` (EAS_NO_VCS + EAS_PROJECT_ROOT=frontend).
node_modules/
.expo/
dist/
web-build/
.metro-cache/
coverage/
*.log
*.log.txt
*.hprof
npm-debug.*
yarn-debug.*
yarn-error.*

# Caches/builds Android locaux: EAS reconstruit tout côté serveur.
android/.gradle/
android/build/
android/app/build/

# Secrets locaux — .env jamais sur EAS
.env
.env.*
!.env.example

# Keystores : exclure les backups ; inclure android-keystore.jks pour credentialsSource: local
*.jks
!android-keystore.jks
# credentials.json requis sur EAS quand android.credentialsSource = local (sinon clé E9:26:B0…)

# Tests / CI locaux (inutiles pour compiler l’APK)
e2e/
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
vitest.config.*
maestro/
