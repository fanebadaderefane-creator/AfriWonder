{
  "expo": {
    "name": "AfriWonder",
    "slug": "afriwonder-production",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "afriwonder",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.afriwonder.app",
      "usesAppleSignIn": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Micro pour messages vocaux et appels audio/vidéo AfriChat",
        "NSCameraUsageDescription": "Caméra pour photos, vidéos, appels vidéo et live streaming",
        "NSPhotoLibraryUsageDescription": "Choisir des photos et vidéos (profil, publication, messages)",
        "NSPhotoLibraryAddUsageDescription": "Enregistrer des photos et vidéos AfriWonder dans votre galerie",
        "NSLocationWhenInUseUsageDescription": "AfriWonder utilise votre position pour les services locaux et recommandations proches de vous.",
        "NSContactsUsageDescription": "Trouver vos amis déjà sur AfriWonder à partir de vos contacts (synchronisation locale et opt-in).",
        "NSFaceIDUsageDescription": "Authentifier rapidement les actions sensibles (paiement, accès au portefeuille).",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification",
          "voip"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "itms-apps"
        ]
      }
    },
    "android": {
      "package": "com.afriwonder.app",
      "versionCode": 35,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "READ_CONTACTS",
        "USE_FULL_SCREEN_INTENT",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_PHONE_CALL",
        "FOREGROUND_SERVICE_MICROPHONE",
        "FOREGROUND_SERVICE_CAMERA",
        "DISABLE_KEYGUARD",
        "TURN_SCREEN_ON",
        "MANAGE_OWN_CALLS"
      ],
      "blockedPermissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidAdiRegistration.js",
      "./plugins/withAndroidDeferFirebaseInit.js",
      "./plugins/withAndroidLargeHeap.js",
      "./plugins/withAndroidNotifeeMaven.js",
      "./plugins/withAndroidJitsiWebRtcMaven.js",
      "./plugins/withAndroidNotifeeForegroundService.js",
      "./plugins/withAndroidNotificationIconDrawable.js",
      "./plugins/withAndroidTurnCleartext.js",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "minSdkVersion": 29
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-router",
      "expo-web-browser",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Prendre des photos et vidéos (publication, live, AR effets temps réel)",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "Enregistrer le son avec vos vidéos AfriWonder",
          "enableCodeScanner": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-image-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "Enregistrer les photos et vidéos AfriWonder dans votre galerie.",
          "savePhotosPermission": "Enregistrer les photos et vidéos AfriWonder dans votre galerie.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/pwa-icon-192.png",
          "color": "#FF6B00",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-pip",
        {}
      ],
      "expo-apple-authentication",
      "react-native-iap"
    ],
    "notification": {
      "icon": "./assets/images/pwa-icon-192.png",
      "color": "#FF6B00",
      "androidMode": "default",
      "androidCollapsedTitle": "AfriWonder"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "54406371-5aa5-4bf1-8f80-b64b9f1e72fc"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "owner": "abdoulayefane-afriwonder-production"
  }
}
