{
  "expo": {
    "name": "AfriWonder",
    "slug": "afriwonder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "afriwonder",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.afriwonder.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Enregistrer des messages vocaux dans AfriChat",
        "NSCameraUsageDescription": "Prendre des photos et vidéos (profil, publication, messages, live streaming)",
        "NSPhotoLibraryUsageDescription": "Choisir des photos et vidéos (profil, publication, messages)",
        "UIBackgroundModes": ["audio", "fetch", "remote-notification"]
      }
    },
    "android": {
      "package": "com.afriwonder.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/pwa-icon-192.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/pwa-icon-192.png",
          "color": "#FF6B00",
          "defaultChannel": "default"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/images/pwa-icon-192.png",
      "color": "#FF6B00",
      "androidMode": "default",
      "androidCollapsedTitle": "AfriWonder"
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-4000-8000-000000000000"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/00000000-0000-4000-8000-000000000000"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
