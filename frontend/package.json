{
  "name": "frontend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "EXPO_NO_TELEMETRY=1 expo start --web --tunnel --port 3000",
    "start:expo-only": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=forks --maxWorkers=1 --minWorkers=1 --fileParallelism=false",
    "test:coverage": "vitest run --pool=forks --maxWorkers=1 --minWorkers=1 --fileParallelism=false --coverage",
    "test:e2e": "vitest run e2e",
    "maestro:smoke": "maestro test maestro/smoke.yaml",
    "maestro:smoke:logged-in": "maestro test maestro/smoke-logged-in.yaml",
    "maestro:wallet": "maestro test maestro/payments-wallet-smoke.yaml",
    "verify": "expo lint && npm run typecheck && npm run test:coverage",
    "quality": "npm run verify",
    "standards:mobile": "npm run verify",
    "eas:android:preview": "node ./scripts/eas-build-from-app-root.cjs --platform android --profile preview",
    "eas:android:production": "node ./scripts/eas-build-from-app-root.cjs --platform android --profile production",
    "android:aab:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android-bundle-release-windows.ps1",
    "android:windows:defender-exclude": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/defender-exclude-frontend-folder.ps1"
  },
  "dependencies": {
    "@babel/runtime": "^7.20.6",
    "@expo/metro-runtime": "^6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@notifee/react-native": "^9.1.8",
    "@peculiar/webcrypto": "^1.5.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.2.12",
    "@tanstack/react-query": "^5.97.0",
    "axios": "^1.15.0",
    "expo": "~54.0.34",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-av": "^16.0.8",
    "expo-blur": "~15.0.8",
