# =============================================================================
# AfriWonder Backend – variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs (au minimum les obligatoires).
# Le serveur charge toujours backend/.env (même si vous lancez depuis la racine du projet).
# Pour les scripts (migrate, seed) : lancer depuis backend/ (cd backend && npm run ...).
#
# Audit roadmap Phase 1 (2026) :
# - Secrets : Doppler (sync Render/Vercel/GitHub) ou variables manuelles — jamais dans le dépôt.
# - Charge API cible : voir npm run load-test:1000rps (health) — valider sur l’infra réelle.
# - Supabase : DATABASE_URL = chaîne Postgres du projet (pooler 6543 recommandé côté serverless).
# =============================================================================

# --- OBLIGATOIRES (sans elles, login et DB échouent) ---
DATABASE_URL="postgresql://user:password@localhost:5432/afriwonder"
JWT_SECRET="generez_64_bytes_hex_minimum_avec_openssl_rand_hex_64"
JWT_REFRESH_SECRET="generez_64_bytes_hex_minimum_avec_openssl_rand_hex_64"

# TLS (Supabase pooler, Neon, Render…) : ne pas définir NODE_TLS_REJECT_UNAUTHORIZED=0 — cela affaiblit
# TLS pour tout le processus Node. Le pool PostgreSQL dans src/config/database.ts applique déjà
# ssl.rejectUnauthorized=false sur les hôtes cloud reconnus.

# --- Serveur ---
# PORT=3000
# NODE_ENV=development

# --- CORS / Frontend ---
# PWA Vite + Expo web (Metro) : inclure explicitement le port utilisé par le navigateur.
# CORS_ORIGIN=http://localhost:5173,http://localhost:8081,http://localhost:8082
# (Sans variable : backend/src/app.ts ajoute déjà 5173, 8081, 8082, 19000, 19006, 127.0.0.1:* en dev.)
# APP_URL=http://localhost:3000
# Origine publique de la PWA (URLs absolues dans les push Web : ouverture au bon écran au tap)
# APP_PUBLIC_URL=https://afriwonder.com

# --- JWT (optionnel) ---
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=30d

# --- Santé / Monitoring ---
# HEALTH_API_KEY=
# SENTRY_DSN=
# LOG_FORMAT=json
# En production: SENTRY_DSN obligatoire (le serveur refuse de démarrer sans DSN).

# --- Base de données ---
# DATABASE_POOL_MAX=10

# --- Admin / Plateforme ---
# SUPER_ADMIN_EMAIL=admin@example.com
# PLATFORM_USER_ID=00000000-0000-0000-0000-000000000000

# --- Jobs internes (crowdfunding) ---
# Statut des nouvelles campagnes : omettre ou ≠ active → "pending" (validation admin). active → publié direct.
# CROWDFUNDING_DEFAULT_CAMPAIGN_STATUS=pending
# Intervalle min. 60s. Défaut : 15 min (remboursements auto campagnes expirées non financées).
# CROWDFUNDING_AUTO_REFUND_INTERVAL_MS=900000

# --- OAuth Google ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- OAuth Facebook ---
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback

# --- Live (Agora) ---
# AGORA_APP_ID=
# AGORA_APP_CERTIFICATE=
# CRON_SECRET=
# LIVE_CLEANUP_SECRET=
# Durée token Agora (secondes, max 604800)
# AGORA_TOKEN_EXPIRE_SECONDS=86400

# --- Paid Video Calls (User ↔ Star) — module isolé ---
# Taux de commission plateforme sur chaque appel (default 0.20 = 20 %)
# STAR_CALL_PLATFORM_COMMISSION=0.20
# Prix unitaire d'une extension +5 min en FCFA (default 500)
# STAR_CALL_EXTENSION_PRICE_FCFA=500
# Pas fixe entre débuts de créneaux (CdC ex. 18:00 / 18:10 / 18:20), en minutes — défaut 10
# STAR_CALL_SLOT_STEP_MINUTES=10
# Annulation fan hors fenêtre « anticipée » : part remboursée (0–1), défaut 0.5 = 50 %, le reste = frais (star + commission)
# STAR_CALL_FAN_LATE_CANCEL_REFUND_RATE=0.5
# Fenêtre « anticipée » pour remboursement intégral fan (minutes avant le créneau), défaut 30
# STAR_CALL_REFUND_CANCEL_WINDOW_MIN=30
# No-show : fenêtre avant de traiter l’absence (minutes), défaut 2 pour fan et star
# STAR_CALL_FAN_NO_SHOW_WINDOW_MIN=2
# STAR_CALL_STAR_NO_SHOW_WINDOW_MIN=2
# Secret exigé par X-Worker-Secret pour déclencher le reaper no-show
# STAR_CALL_WORKER_SECRET=

# --- Moteur reco Python (optionnel) — GET {URL}/videos?limit=&seed=&user_id= ---
# RECOMMENDATION_ENGINE_URL=https://reco.internal/api
# RECOMMENDATION_ENGINE_KEY=

# --- MTN MoMo Collection (expansion Phase 4) — sinon stub ---
# MTN_MOMO_RTP_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay
# MTN_MOMO_ACCESS_TOKEN= (OAuth2 client credentials)
# MTN_MOMO_TARGET_ENVIRONMENT=sandbox
# MTN_MOMO_SUBSCRIPTION_KEY= (synonyme MTN_MOBILE_MONEY_SUBSCRIPTION_KEY)

# --- Stripe Connect (Afrique / compte connecté) ---
# STRIPE_CONNECTED_ACCOUNT_ID=

# --- Roadmap produit (affichées dans GET /api/platform/config) ---
# CREATOR_PARTNERS_TARGET=100
# PILOT_COUNTRIES=SN,CI,ML
# Télémédecine activée par défaut en production (annuaire docteurs/pharmacies + RDV).
# Mettre à "false" si vous voulez la désactiver explicitement avant validation médicale.
TELEMEDICINE_ENABLED=true

# --- Redis (cache / sockets / rate limit distribué / révocation JWT) ---
# Obligatoire si NODE_ENV=production (le serveur refuse de démarrer sans REDIS_URL en prod).
# REDIS_URL=redis://localhost:6379

# --- TURN/WebRTC (credentials temporaires HMAC via API backend) ---
# TURN_URL=turns:turn.example.com:5349?transport=tcp
# TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
# TURN_SHARED_SECRET=change_me_turn_secret
# TURN_REALM=afriwonder.com
# TURN_CREDENTIAL_TTL_SEC=3600

# --- Upload / stockage (Cloudflare R2) ---
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=afriwonder
# R2_PUBLIC_URL=
# R2_DIRECT_PUBLIC_URL=

# --- Traduction (messages / chat) — LibreTranslate ---
# LIBRETRANSLATE_URL=https://libretranslate.de
# LIBRETRANSLATE_API_KEY=

# --- Supabase (migration Phase 1 — optionnel, en parallèle de Prisma) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ... (rarement nécessaire côté API Express ; préférer flux Prisma)
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (backend uniquement — jamais exposé au client)
# SUPABASE_JWT_SECRET= (si validation JWT Supabase côté API)
# Bucket Storage (upload PUT via POST /api/upload/supabase/presign)
# SUPABASE_STORAGE_BUCKET=afriwonder-media

# --- Paiements ---
# Stripe (Checkout + webhook brut /api/payments/stripe/webhook — STRIPE_WEBHOOK_SECRET requis pour verify)
# STRIPE_SECRET_KEY=sk_live_... ou sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_... (Dashboard Stripe → Webhooks → signing secret)
# PAYMENT_WEBHOOK_SECRET=
# WEBHOOK_SECRET=
# Orange Money (Web Payment) — à copier dans backend/.env avec les valeurs Orange (ne pas committer .env)
# APP_URL=https://ton-backend-public.ngrok.io  (ou URL prod) — utilisé pour notify_url webhook ; localhost invisible d’Orange
# CORS_ORIGIN=http://localhost:5173  (origine du front ; utilisée aussi pour return_url recharge wallet)
#
# Identifiants API Web Payment (fiche Orange / portail : ce n’est PAS le mot de passe du simulateur)
# ORANGE_MONEY_MERCHANT_ID=MerchantWP01xxx   (ex. identifiant marchand Web Payment — valeur exacte selon Orange)
# ORANGE_MONEY_API_KEY=                       (clé marchande / token Bearer — obtenue via la procédure Orange, pas le PIN agent)
# ORANGE_MONEY_API_URL=https://api.orange.ml  (si Orange donne une URL sandbox, la mettre ici)
# ORANGE_MONEY_REGION=ML
#
# OAuth Orange (vérif transaction status api.orange.com — si requis par ton intégration)
# ORANGE_MONEY_CLIENT_ID=
# ORANGE_MONEY_CLIENT_SECRET=
#
# Web Payment → webhook crédit wallet : même base que APP_URL
# ORANGE_MONEY_WEBHOOK_SECRET=
# ORANGE_MONEY_ENV=test
# ORANGE_MONEY_TRUST_WEBHOOK=1  (uniquement pour débloquer des tests si verify API échoue — à retirer en prod)
#
# Sans MERCHANT_ID + API_KEY : AfriWonder reste en simulation (page mockOrange). Pour forcer le mock même avec clés :
# ORANGE_MONEY_MOCK=true
#
# GET /api/live/wallet/recharge/confirm — secours uniquement
# WALLET_RECHARGE_ALLOW_RETURN_CONFIRM=1
#
# Test abonné (paiement) : numéro type 7701101162 dans le formulaire — pas le MSISDN marchand 77019…
# Wave (SN, CI, ML — roadmap Phase 2)
# WAVE_API_KEY=
# WAVE_BUSINESS_ID=
# WAVE_API_URL=https://api.wave.com/v1
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_API_URL=https://api-m.paypal.com

# --- Retraits ---
# WITHDRAWAL_DELAY_HOURS=48

# --- Email transactionnel (Resend — prioritaire si défini, sinon SMTP ci-dessous) ---
# RESEND_API_KEY=re_...
# RESEND_FROM=AfriWonder <no-reply@ton-domaine-verifie.resend.dev>

# --- Email / SMS / Notifications ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@afriwonder.app
# SMS_PROVIDER=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# PUSH_WEBHOOK_URL=
# Web Push (même jeu de clés que le frontend VITE_VAPID_PUBLIC_KEY pour la clé publique)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@afriwonder.app
# FIREBASE_SERVER_KEY=
# FCM_PROJECT_ID=
# FCM_PRIVATE_KEY_ID=
# FCM_PRIVATE_KEY=
# FCM_CLIENT_EMAIL=
# FCM_CLIENT_ID=
# SMS_ORDER_NOTIFICATIONS=false

# --- Civic / Pétitions ---
# RECAPTCHA_SECRET=

# --- Sécurité / Fraude / AML ---
# AML_THRESHOLD_XOF=1000000
# FRAUD_MAX_PAYMENT_AMOUNT=5000000
# FRAUD_MAX_FAILED_LAST_HOUR=5
# FRAUD_MAX_SUCCESS_WINDOW_MIN=15
# FRAUD_MAX_SUCCESS_IN_WINDOW=10
# WALLET_PIN_SALT=

# --- Microcrédit ---
# STRICT_KYC_FINANCE=false
# LOAN_OVERDUE_DAYS=30

# --- Autres ---
# Bêta (roadmap ~500 utilisateurs) : prioritaire sur platformSettings.early_access_max_users
# EARLY_ACCESS_MAX_USERS=500
# APP_COUNTRY=
# PUBLIC_API_KEYS=
# PUBLIC_API_DEV_KEY=afw_public_dev_key
# PUBLIC_API_RATE_LIMIT_PER_MIN=60
# PUBLIC_API_DAILY_QUOTA=2000
# MARKETPLACE_PHASE1_SUBSCRIPTION_ONLY=false
# CANCELLATION_DEADLINE_HOURS=24
# VIEW_SALT=
# CRON_SECRET= (utilisé aussi pour news, events)
# NEWS_CRON_SECRET=
# EVENTS_REMINDERS_SECRET=
# ADMIN_PASSWORD=

# --- Vidéo : rendu léger (MP4 ~480p, réseaux faibles) ---
# VIDEO_LOW_QUALITY_RENDITION=0 désactive ffmpeg + upload R2.
# VIDEO_LOW_QUALITY_DELAY_MS=120000 délai après publication (laisse finir le transcodage compat éventuel).
# VIDEO_LOW_Q_CRF=32 VIDEO_LOW_Q_PRESET=veryfast VIDEO_LOW_Q_TIMEOUT_MS=360000

# === AGORA CLOUD RECORDING ===
AGORA_CUSTOMER_KEY=your_agora_customer_key_here
AGORA_CUSTOMER_SECRET=your_agora_customer_secret_here
AGORA_TOKEN_EXPIRE_SECONDS=86400

# === CLOUDFLARE R2 (replays) ===
# Réutiliser ou ajuster les variables R2 déjà définies plus haut :
# R2_BUCKET_NAME=afriwonder-replays
# R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
