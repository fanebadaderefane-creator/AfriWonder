generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           String                    @id @default(uuid())
  email                        String                    @unique
  username                     String                    @unique
  password_hash                String
  full_name                    String?
  profile_image                String?
  profile_cover_url            String?
  is_private                   Boolean                   @default(false)
  preferred_language           String?
  timezone                     String?
  theme                        String?                   @default("system")
  preferred_categories         Json?
  role                         String                    @default("user")
  is_verified                  Boolean                   @default(false)
  created_at                   DateTime                  @default(now())
  updated_at                   DateTime                  @updatedAt
  country                      String?
  account_suspended            Boolean                   @default(false)
  suspended_at                 DateTime?
  suspended_reason             String?
  bio                          String?
  location                     String?
  website                      String?
  replay_premium               Boolean                   @default(false)
  /// Abonnement AfriWonder Pro créateur (Phase 9) — dérivé aussi de CreatorSubscription ; flag cache rapide UI.
  is_afriwonder_pro            Boolean                   @default(false)
  data_saver_mode              Boolean                   @default(false)
  /// E-mail d’alerte lors d’une connexion depuis un appareil / navigateur non vu récemment.
  login_alerts_enabled         Boolean                   @default(true)
  shadow_banned                Boolean                   @default(false)
  referral_code                String?                   @unique
  /// Lien compte Supabase Auth (migration Phase 1) — optionnel
  supabase_id                  String?                   @unique
  /// Sign in with Apple — sujet stable (`sub`) quand l’email n’est plus renvoyé
  apple_id                     String?                   @unique
  phone_verified               Boolean                   @default(false)
  monetization_enabled         Boolean                   @default(false)
  monetization_suspended_at    DateTime?
  messaging_e2e_enabled        Boolean                   @default(false)   // CPO 4.40 — préférence E2E (implémentation à venir)
  /// Accusés de lecture (tics bleus) : si false, n’envoie pas « lu » aux autres et masque les tics bleus sur ses propres messages (CDC confidentialité)
  messaging_read_receipts_enabled Boolean                @default(true)
  /// Préférences écran CDC modération (ex. silentLeave, forwardLimit) — appliquées côté produit plus tard
  messaging_cdc_moderation     Json?
  ad_campaigns                 AdCampaign[]
  addresses                    Address[]
  airtime_recharges            AirtimeRecharge[]
  appointments_as_patient      Appointment[]             @relation("AppointmentPatient")
  article_comments             ArticleComment[]
  article_likes                ArticleLike[]
  article_views                ArticleView[]
  bill_payments                BillPayment[]
  candidate_profile            CandidateProfile?
  candidate_ratings_given      CandidateRating[]         @relation("CandidateRatingsGiven")
  candidate_ratings_received   CandidateRating[]         @relation("CandidateRatingsReceived")
  cart                         Cart?
  certificates                 Certificate[]
  civic_petitions_created      CivicPetition[]
  comments                     Comment[]
  cf_comments                  CrowdfundingComment[]
  communities_created          Community[]
  community_members            CommunityMember[]
  company_profile              CompanyProfile?
  company_ratings_given        CompanyRating[]           @relation("CompanyRatingsGiven")
  company_ratings_received     CompanyRating[]           @relation("CompanyRatingsReceived")
  conversations_user1          Conversation[]            @relation("User1")
  conversations_user2          Conversation[]            @relation("User2")
  conversation_groups_created  ConversationGroup[]       @relation("ConversationGroupCreator")
  conversation_group_members   ConversationGroupMember[]
  group_messages_sent          GroupMessage[]
  coupons_created              Coupon[]
  courses_created              Course[]
  crowdfunding_campaigns     Campaign[]
  course_providers             CourseProvider?
  course_reviews               CourseReview[]
  course_wishlist              CourseWishlist[]
  creator_level                CreatorLevel?
  creator_subscriptions        CreatorSubscription[]
  creator_support_received     CreatorSupport[]          @relation("CreatorSupportReceived")
  creator_support_given        CreatorSupport[]          @relation("CreatorSupportGiven")
  daily_mission_completions    DailyMissionCompletion[]
  doctor_profile               Doctor?
  driver_profile               Driver?
  enrollments                  Enrollment[]
  events_organized             Event[]
  event_attendances            EventAttendance[]
  event_chat_messages          EventChatMessage[]
  event_comments               EventComment[]
  event_featured_payments      EventFeaturedPayment[]
  event_likes                  EventLike[]
  event_payments               EventPayment[]
  event_tickets                EventTicket[]
  follows                      Follow[]                  @relation("Follower")
  following                    Follow[]                  @relation("Following")
  follow_requests_sent         FollowRequest[]           @relation("FollowRequestRequester")
  follow_requests_received     FollowRequest[]           @relation("FollowRequestTarget")
  food_orders_customer         FoodOrder[]               @relation("FoodOrderCustomer")
  food_orders_delivery         FoodOrder[]               @relation("FoodOrderDelivery")
  insurance_claims             InsuranceClaim[]
  insurance_policies           InsurancePolicy[]
  insurance_providers          InsuranceProvider[]
  insurance_quote_requests     InsuranceQuoteRequest[]
  jobs_created                 Job[]
  job_applications             JobApplication[]
  likes                        Like[]
  live_cohosts_as_guest        LiveCoHost[]              @relation("LiveCoHostGuest")
  live_cohosts_as_creator      LiveCoHost[]              @relation("LiveCoHostCreator")
  live_subscriptions_created   LiveCreatorSubscription[] @relation("LiveSubscriptionsCreated")
  live_subscriptions_given     LiveCreatorSubscription[] @relation("LiveSubscriptionsGiven")
  live_likes                   LiveLike[]
  live_moderator_of            LiveModerator[]
  live_polls_created           LivePoll[]
  live_poll_votes              LivePollVote[]
  live_streams                 LiveStream[]
  live_top_donors              LiveTopDonor[]
  live_viewers                 LiveViewer[]
  loan_requests_borrowed       LoanRequest[]
  loyalty_program              LoyaltyProgram?
  messages_sent                Message[]
  message_reports              MessageReport[]
  moderation_reports           Moderation[]              @relation("ModerationReporter")
  monetization_requests        MonetizationRequest[]
  news_articles_authored       NewsArticle[]
  news_premium_subscriptions   NewsPremiumSubscription[]
  notifications                Notification[]
  notification_logs            NotificationLog[]
  notification_preference      NotificationPreference?
  push_subscriptions           PushSubscription[]
  orders                       Order[]
  order_buyer_reviews_received OrderBuyerReview[]        @relation("BuyerReviewBuyer")
  order_buyer_reviews_given    OrderBuyerReview[]        @relation("BuyerReviewSeller")
  order_reviews                OrderReview[]             @relation("OrderReviewUser")
  petition_comments            PetitionComment[]
  petition_comment_likes       PetitionCommentLike[]
  petition_signatures          PetitionSignature[]       @relation("PetitionSigner")
  pharmacies_owned             Pharmacy[]
  playlists                    Playlist[]
  products                     Product[]
  product_questions            ProductQuestion[]         @relation("ProductQuestionAuthor")
  properties_owned             Property[]
  property_visit_requests      PropertyVisitRequest[]
  referrals_received           Referral[]                @relation("Referred")
  referrals_sent               Referral[]                @relation("Referrer")
  reports                      Report[]                  @relation("Reporter")
  restaurants_owned            Restaurant[]
  reviews                      Review[]
  rides_as_driver              Ride[]                    @relation("RideDriver")
  rides_as_passenger           Ride[]                    @relation("RidePassenger")
  saves                        Save[]
  save_collections             SaveCollection[]
  video_poll_votes             VideoPollVote[]
  comment_reactions            CommentReaction[]
  saved_jobs                   SavedJob[]
  saved_petitions              SavedPetition[]
  seller_profile               SellerProfile?
  seller_reviews_received      SellerReview[]            @relation("SellerReviewed")
  seller_reviews_given         SellerReview[]            @relation("SellerReviewAuthor")
  seller_subscriptions         SellerSubscription[]      @relation("SellerSubscriptions")
  seller_wallet                SellerWallet?
  service_bookings_customer    ServiceBooking[]          @relation("BookingCustomer")
  service_provider             ServiceProvider?          @relation("ServiceProvider")
  service_reviews              ServiceReview[]           @relation("ServiceReviewCustomer")
  stories                      Story[]
  story_reactions              StoryReaction[]
  story_poll_votes             StoryPollVote[]
  subscriptions                Subscription[]
  support_messages             SupportMessage[]
  support_tickets              SupportTicket[]
  tickets                      Ticket[]
  transactions                 Transaction[]
  travel_bookings              TravelBooking[]
  user_badges                  UserBadge[]
  blocked_by                   UserBlock[]               @relation("Blocked")
  blocking                     UserBlock[]               @relation("Blocker")
  user_cloud_files             UserCloudFile[]
  user_level                   UserLevel?
  user_loyalty_entries         UserLoyalty[]
  user_news_preference         UserNewsPreference?
  user_points                  UserPoints?
  presence                     UserPresence?
  user_strikes                 UserStrike[]
  user_verification            UserVerification?
  videos                       Video[]
  video_tips_received          VideoTip[]                @relation("TipReceiver")
  video_tips_sent              VideoTip[]                @relation("TipSender")
  view_history                 ViewHistory[]
  wallets                      Wallet[]
  wallet_security              WalletSecurity?
  wishlist                     Wishlist[]
  product_alerts               ProductAlert[]
  preorders                    Preorder[]
  product_offers               ProductOffer[]
  product_auctions_sold        ProductAuction[]
  product_auctions_bid         ProductAuction[]    @relation("AuctionBidder")
  travel_price_alerts          TravelPriceAlert[]
  group_buys_created           GroupBuy[]
  group_buy_participations     GroupBuyParticipant[]
  experiment_assignments       UserExperimentAssignment[]
  ride_shares_driven           RideShare[]
  ride_share_bookings          RideShareBooking[]
  withdrawals                  Withdrawal[]
  wonder_relations_received    WonderRelation[]          @relation("WonderCreator")
  wonder_relations_given       WonderRelation[]          @relation("Wonderer")
  account_deletion_requests    AccountDeletionRequest[]
  admin_audit_logs             AdminAuditLog[]
  data_export_requests         DataExportRequest[]
  developer_revenue            DeveloperRevenue?         @relation("DeveloperRevenues")
  developer_subscription       DeveloperSubscription?    @relation("DeveloperSubscriptions")
  mini_app_installs            MiniAppInstall[]          @relation("MiniAppInstalls")
  mini_app_transactions        MiniAppTransaction[]      @relation("MiniAppTransactions")
  mini_app_reviews             MiniAppReview[]
  developer_mini_apps          MiniApp[]                 @relation("DeveloperMiniApps")
  security_logs                SecurityLog[]
  suspicious_activity_alerts   SuspiciousActivityAlert[]
  two_factor_auth              User2FA?
  cookie_preferences           UserCookiePreference?
  legal_acceptances            UserLegalAcceptance[]
  posts                       Post[]
  post_comments               PostComment[]
  post_comment_reactions      PostCommentReaction[]
  post_poll_votes             PostPollVote[]
  business_page               BusinessPage?
  payment_requests_from       PaymentRequest[]          @relation("PaymentRequestFrom")
  brand_deals_as_creator      BrandDeal[]
  group_calls_created         GroupCall[]
  group_call_participations    GroupCallParticipant[]
  user_sessions               UserSession[]
  user_e2ee_devices           UserE2eeDevice[]
  user_e2ee_prekeys           UserE2eePrekey[]
  parcel_shipments            ParcelShipment[]
  close_friends               CloseFriend[]              @relation("CloseFriendOwner")
  close_friend_of              CloseFriend[]             @relation("CloseFriendTarget")
  virtual_cards               VirtualCard[]
  international_transfers_sent InternationalTransfer[]   @relation("InternationalTransferSender")
  payment_preauths            PaymentPreauth[]
  creator_contracts           CreatorContract[]
  live_age_acknowledgments    LiveAgeAcknowledgment[]
  live_bell_subscriptions     LiveCreatorBellSubscriber[] @relation("LiveBellSubscriber")
  live_bell_watchers          LiveCreatorBellSubscriber[] @relation("LiveBellCreator")
  tontines_created            Tontine[]                   @relation("TontineCreator")
  tontine_memberships         TontineMember[]             @relation("TontineMemberUser")
  tontine_cycles_received     TontineCycle[]              @relation("TontineCycleBeneficiary")
  bus_bookings                BusBooking[]                @relation("BusBookingPassenger")
  hotel_bookings              HotelBooking[]              @relation("HotelBookingGuest")
  savings_plans               SavingsPlan[]               @relation("SavingsPlanOwner")
  utility_bill_payments       UtilityBillPayment[]        @relation("UtilityBillUser")
  live_pinned_products        LivePinnedProduct[]         @relation("LivePinnedProductPinner")

  // ==========================================================================
  // PAID VIDEO CALLS (User ↔ Star) — vague 9
  // ==========================================================================
  star_profile                StarProfile?                @relation("StarProfileOwner")
  star_bookings_as_fan        StarBooking[]               @relation("StarBookingFan")
  star_bookings_as_star       StarBooking[]               @relation("StarBookingStar")
  star_ratings_given          StarRating[]                @relation("StarRatingFan")
  star_ratings_received       StarRating[]                @relation("StarRatingStar")
  star_disputes_opened        StarDispute[]               @relation("StarDisputeOpener")
  star_dispute_messages       StarDisputeMessage[]        @relation("StarDisputeAuthor")
}

/// Demande de monétisation — créateur envoie, admin valide
model MonetizationRequest {
  id            String    @id @default(uuid())
  creator_id    String
  status        String    @default("pending")
  reviewed_by   String?
  reviewed_at   DateTime?
  reject_reason String?
  created_at    DateTime  @default(now())
  creator       User      @relation(fields: [creator_id], references: [id], onDelete: Cascade)

  @@index([creator_id])
  @@index([status])
}

/// Posts texte / image (feed social type Facebook) — CPO 2.4, 2.5, 2.7
model Post {
  id           String      @id @default(uuid())
  user_id      String
  text         String?
  image_url    String?     // première image (rétrocompat) ; si images[] présent, priorité aux PostImage
  visibility   String      @default("public")
  scheduled_at DateTime?
  is_pinned    Boolean     @default(false)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  user         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  poll         PostPoll?
  images       PostImage[] // carrousel multi-images (CPO 2.5, 2.7)
  comments     PostComment[]

  @@index([user_id])
  @@index([visibility, created_at])
  @@index([scheduled_at])
}

/// Commentaires sur un post / Moment (feed social)
model PostComment {
  id         String        @id @default(uuid())
  post_id    String
  user_id    String
  content    String
  parent_id  String?
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  post       Post          @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent     PostComment?  @relation("PostCommentReplies", fields: [parent_id], references: [id], onDelete: SetNull)
  replies    PostComment[] @relation("PostCommentReplies")
  reactions  PostCommentReaction[]

  @@index([post_id])
  @@index([user_id])
  @@index([parent_id])
  @@map("post_comments")
}

model PostCommentReaction {
  id         String      @id @default(uuid())
  comment_id String
  user_id    String
  type       String      @default("like")
  created_at DateTime    @default(now())
  comment    PostComment @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, user_id])
  @@index([comment_id])
  @@index([user_id])
  @@map("post_comment_reactions")
}

/// Image d'un carrousel de post (CPO 2.5, 2.7)
model PostImage {
  id        String   @id @default(uuid())
  post_id   String
  image_url String
  position  Int      @default(0)
  created_at DateTime @default(now())
  post      Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
}

/// Sondage dans un post (CPO 2.20)
model PostPoll {
  id        String    @id @default(uuid())
  post_id   String    @unique
  question  String
  options   Json
  ends_at   DateTime?
  created_at DateTime @default(now())
  post      Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  votes     PostPollVote[]

  @@index([post_id])
}

model PostPollVote {
  id           String   @id @default(uuid())
  poll_id      String
  user_id      String
  option_index Int
  created_at   DateTime @default(now())
  poll         PostPoll @relation(fields: [poll_id], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([poll_id, user_id])
  @@index([poll_id])
  @@index([user_id])
}

/// Liste « proches » / close friends (CPO 1.18)
model CloseFriend {
  id        String   @id @default(uuid())
  user_id   String
  friend_id String
  created_at DateTime @default(now())
  user      User     @relation("CloseFriendOwner", fields: [user_id], references: [id], onDelete: Cascade)
  friend    User     @relation("CloseFriendTarget", fields: [friend_id], references: [id], onDelete: Cascade)

  @@unique([user_id, friend_id])
  @@index([user_id])
  @@index([friend_id])
}

/// Mots interdits pour filtrage commentaires (CPO 2.43)
model BannedWord {
  id        String   @id @default(uuid())
  word      String   @unique
  is_active Boolean  @default(true)
  created_at DateTime @default(now())

  @@index([word])
  @@index([is_active])
}

/// Chapitres pour vidéo VOD (début/fin en secondes)
model VideoChapter {
  id             String   @id @default(uuid())
  video_id       String
  title          String
  start_time_sec Int
  end_time_sec   Int?
  created_at     DateTime @default(now())
  video          Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([video_id])
}

/// Demande de paiement par QR (génération + paiement par scan)
model PaymentRequest {
  id           String    @id @default(uuid())
  from_user_id String
  amount       Float
  currency     String    @default("XOF")
  status       String    @default("pending")
  qr_token     String    @unique
  expires_at   DateTime
  paid_at      DateTime?
  paid_by_id   String?
  created_at   DateTime  @default(now())
  from_user    User      @relation("PaymentRequestFrom", fields: [from_user_id], references: [id], onDelete: Cascade)

  @@index([from_user_id])
  @@index([qr_token])
  @@index([status])
  @@index([expires_at])
}

/// Page entreprise (type Facebook business page)
model BusinessPage {
  id          String   @id @default(uuid())
  user_id     String   @unique
  name        String
  slug        String   @unique
  description String?
  avatar_url  String?
  cover_url   String?
  website     String?
  phone       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([slug])
}

/// Produits mis en avant pendant un live (live commerce)
model LiveStreamProduct {
  id         String      @id @default(uuid())
  live_id    String
  product_id String
  position   Int         @default(0)
  created_at DateTime    @default(now())
  live       LiveStream  @relation(fields: [live_id], references: [id], onDelete: Cascade)
  product    Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([live_id, product_id])
  @@index([live_id])
  @@index([product_id])
}

/// Config cashback plateforme (pourcentage sur commandes)
model CashbackConfig {
  id              String   @id @default(uuid())
  percent         Float    @default(0)
  min_order_amount Float?
  is_active       Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([is_active])
}

/// Bot de chat (réponses automatiques / mini-apps dans chat)
model ChatBot {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  avatar_url   String?
  is_active    Boolean  @default(true)
  welcome_message String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([username])
  @@index([is_active])
}

/// Filtres vidéo (côté client ; backend = catalogue)
model VideoFilter {
  id            String   @id @default(uuid())
  name          String
  thumbnail_url String?
  config        Json?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  videos        Video[]

  @@index([is_active])
}

/// Packs de stickers pour messagerie
model StickerPack {
  id          String    @id @default(uuid())
  name        String
  thumbnail_url String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  stickers   Sticker[]

  @@index([is_active])
}

model Sticker {
  id          String      @id @default(uuid())
  pack_id    String
  url        String
  emoji      String?
  created_at DateTime    @default(now())
  pack      StickerPack  @relation(fields: [pack_id], references: [id], onDelete: Cascade)

  @@index([pack_id])
}

/// Appel groupe (audio/vidéo) — room + participants
model GroupCall {
  id                      String             @id @default(uuid())
  creator_id              String
  room_id                 String             @unique
  status                  String             @default("active")
  type                    String             @default("video")
  started_at              DateTime           @default(now())
  ended_at                DateTime?
  created_at              DateTime           @default(now())
  /// Messagerie : salon pour invites / fin d’appel (socket `group:*`)
  conversation_group_id   String?
  creator                 User               @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  conversation_group      ConversationGroup? @relation(fields: [conversation_group_id], references: [id], onDelete: SetNull)
  participants            GroupCallParticipant[]

  @@index([creator_id])
  @@index([room_id])
  @@index([status])
  @@index([conversation_group_id])
}

model GroupCallParticipant {
  id         String    @id @default(uuid())
  call_id    String
  user_id    String
  joined_at  DateTime @default(now())
  left_at    DateTime?
  role       String    @default("participant")
  call       GroupCall @relation(fields: [call_id], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([call_id, user_id])
  @@index([call_id])
  @@index([user_id])
}

/// Collaboration marques / sponsoring créateur
model BrandDeal {
  id               String   @id @default(uuid())
  creator_id       String
  brand_name       String
  status           String   @default("pending")
  amount           Float?
  currency         String?
  campaign_id      String?
  notes            String?
  deliverables     Json?
  brief_url        String?
  brand_user_id    String?
  platform_fee_pct Float    @default(0.10)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  creator          User     @relation(fields: [creator_id], references: [id], onDelete: Cascade)

  @@index([creator_id])
  @@index([status])
  @@index([brand_user_id])
}

/// Session / appareil connecté (multi-device)
model UserSession {
  id         String   @id @default(uuid())
  user_id    String
  device_id  String?
  user_agent String?
  last_seen  DateTime @default(now())
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([last_seen])
}

/// Device E2E enregistré (clé identité + signed prekey)
model UserE2eeDevice {
  id                       String   @id @default(uuid())
  user_id                  String
  device_id                String
  identity_key_public      String
  signed_prekey_public     String
  signed_prekey_signature  String
  key_algo                 String   @default("x25519")
  app_version              String?
  platform                 String?
  last_seen_at             DateTime @default(now())
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  user                     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, device_id])
  @@index([user_id])
  @@index([device_id])
  @@index([last_seen_at])
}

/// Stock de one-time prekeys (consommables une fois)
model UserE2eePrekey {
  id                  String   @id @default(uuid())
  user_id             String
  device_id           String
  key_id              Int
  public_key          String
  consumed_at         DateTime?
  consumed_by_user_id String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, device_id, key_id])
  @@index([user_id, device_id])
  @@index([consumed_at])
}

/// Services publics / administratifs (liste pour le hub)
model PublicService {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  category    String?
  link_url    String?
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([slug])
  @@index([is_active])
}

model VideoHashtag {
  id         String   @id @default(uuid())
  video_id   String
  tag_name   String
  created_at DateTime @default(now())
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([video_id, tag_name])
  @@index([tag_name])
  @@index([video_id])
}

model VideoCategory {
  id          String   @id @default(uuid())
  video_id    String
  category_id String
  created_at  DateTime @default(now())
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  video       Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([video_id, category_id])
  @@index([video_id])
  @@index([category_id])
}

model Category {
  id               String          @id @default(uuid())
  name             String          @unique
  video_categories VideoCategory[]

  @@index([name])
}

model Video {
  id                    String                @id @default(uuid())
  title                 String
  description           String?
  video_url             String
  /// Rendu MP4 léger (≈480p) pour réseaux faibles ; miroir client `low_quality_playback_url`.
  low_quality_url       String?
  hls_url               String?
  thumbnail_url         String?
  creator_id            String
  visibility            String                @default("public")
  category              String?
  views                 Int                   @default(0)
  likes                 Int                   @default(0)
  comments_count        Int                   @default(0)
  shares                Int                   @default(0)
  saves                 Int                   @default(0)
  duration              Int?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  hashtags              Json?
  music_title           String?
  /// JSON client : filtres, texte/stickers, découpe %, vitesse, piste musique (éditeur mobile).
  editor_metadata       String?
  is_featured           Boolean               @default(false)
  algo_tier             String?               @default("test")
  avg_retention_pct     Float?
  qualified_views_count Int                   @default(0)
  media_type            String?               @default("video")
  remix_of_id           String?
  subtitle_url           String?
  download_allowed      Boolean               @default(false)
  is_premium            Boolean               @default(false)
  trim_start_sec        Int?
  trim_end_sec          Int?
  filter_id             String?
  comments_disabled     Boolean               @default(false)
  comment_visibility    String                @default("everyone")
  /// Phase 23 — afficher d’abord les commentaires des abonnés du créateur (tri côté API).
  comment_subscribers_first Boolean           @default(false)
  hide_likes            Boolean               @default(false)
  scheduled_at          DateTime?
  /// Phase 23 — `duet` | `stitch` quand `remix_of_id` est renseigné.
  remix_kind            String?
  /// Phase 23 — participation à un challenge viral.
  challenge_id          String?
  filter                VideoFilter?          @relation(fields: [filter_id], references: [id], onDelete: SetNull)
  remix_of              Video?                @relation("VideoRemix", fields: [remix_of_id], references: [id], onDelete: SetNull)
  remixes               Video[]               @relation("VideoRemix")
  challenge             VideoChallenge?       @relation(fields: [challenge_id], references: [id], onDelete: SetNull)
  video_poll            VideoPoll?
  chapters              VideoChapter[]
  collaborator_revenues CollaboratorRevenue[]
  video_comments        Comment[]
  video_likes           Like[]
  playlist_items        PlaylistItem[]
  qualified_video_views QualifiedVideoView[]
  video_saves           Save[]
  creator               User                  @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  analytics             VideoAnalytics[]
  video_categories      VideoCategory[]
  video_hashtags        VideoHashtag[]
  video_tips            VideoTip[]
  video_views           VideoView[]
  view_history          ViewHistory[]
  transcoding_jobs      TranscodingJob[]
  subtitle_generations  VideoSubtitleGeneration[]

  @@index([creator_id, created_at])
  @@index([visibility, created_at])
  @@index([category])
  @@index([is_featured])
  @@index([remix_of_id])
  @@index([challenge_id])
  @@index([category], map: "idx_videos_category")
}

/// Phase 23 — sondage attaché à une vidéo (expire 24h après création).
model VideoPoll {
  id         String          @id @default(uuid())
  video_id   String          @unique
  /// Libellés des choix (2 à 4 chaînes).
  options    Json
  expires_at DateTime
  created_at DateTime        @default(now())
  video      Video           @relation(fields: [video_id], references: [id], onDelete: Cascade)
  votes      VideoPollVote[]

  @@index([expires_at])
}

model VideoPollVote {
  id            String    @id @default(uuid())
  poll_id       String
  user_id       String
  option_index  Int
  created_at    DateTime  @default(now())
  poll          VideoPoll @relation(fields: [poll_id], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([poll_id, user_id])
  @@index([poll_id])
}

/// Phase 23 — challenge / hashtag tendance (option sponsor).
model VideoChallenge {
  id                 String    @id @default(uuid())
  /// Hashtag sans # (minuscules).
  hashtag            String    @unique
  title              String
  description        String?
  sponsor_brand      String?
  is_sponsored       Boolean   @default(false)
  revenue_share_note String?
  is_active          Boolean   @default(true)
  created_at         DateTime  @default(now())
  expires_at         DateTime?
  videos             Video[]

  @@index([is_active, created_at])
}

model Like {
  id         String   @id @default(uuid())
  user_id    String
  video_id   String
  type       String   @default("like")
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id])
  @@index([video_id, type])
  @@index([video_id])
  @@index([user_id])
}

model DeveloperSubscription {
  id              String    @id @default(uuid())
  developer_id    String    @unique
  plan_type       String    @default("starter")
  commission_rate Float     @default(0.10)
  status          String    @default("active")
  started_at      DateTime  @default(now())
  expires_at      DateTime?
  cancelled_at    DateTime?
  payment_method  String?
  last_payment_at DateTime?
  next_payment_at DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  developer       User      @relation("DeveloperSubscriptions", fields: [developer_id], references: [id], onDelete: Cascade)

  @@index([developer_id])
  @@index([plan_type])
  @@index([status])
  @@map("developer_subscriptions")
}

model MiniApp {
  id                  String               @id @default(uuid())
  developer_id        String
  name                String
  description         String
  icon_url            String?
  category            String
  version             String               @default("1.0.0")
  status              String               @default("pending")
  featured            Boolean              @default(false)
  installs_count      Int                  @default(0)
  rating              Float                @default(0)
  reviews_count       Int                  @default(0)
  price               String               @default("gratuit")
  permissions         String[]
  screenshots         String[]
  bundle_url          String?
  bundle_hash         String?
  commission_rate     Float
  gmv_total           Float                @default(0)
  revenue_total       Float                @default(0)
  commission_total    Float                @default(0)
  last_transaction_at DateTime?
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  boosts              MiniAppBoost[]
  installs            MiniAppInstall[]
  transactions        MiniAppTransaction[]
  reviews             MiniAppReview[]
  developer           User                 @relation("DeveloperMiniApps", fields: [developer_id], references: [id], onDelete: Cascade)

  @@index([developer_id])
  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([installs_count])
  @@map("mini_apps")
}

/// CPO 8.25 — Notes et avis sur une mini-app
model MiniAppReview {
  id          String   @id @default(uuid())
  mini_app_id String
  user_id     String
  rating      Int      // 1-5
  comment     String?
  created_at  DateTime @default(now())
  mini_app    MiniApp  @relation(fields: [mini_app_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([mini_app_id, user_id])
  @@index([mini_app_id])
  @@index([user_id])
}

model MiniAppTransaction {
  id                String    @id @default(uuid())
  mini_app_id       String
  user_id           String
  amount            Float
  currency          String    @default("XOF")
  commission_rate   Float
  commission_amount Float
  developer_amount  Float
  status            String    @default("pending")
  payment_method    String    @default("orange_money")
  payment_reference String?
  description       String?
  metadata          Json?
  processed_at      DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  mini_app          MiniApp   @relation(fields: [mini_app_id], references: [id], onDelete: Cascade)
  user              User      @relation("MiniAppTransactions", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([mini_app_id])
  @@index([user_id])
  @@index([status])
  @@index([created_at])
  @@map("mini_app_transactions")
}

model MiniAppBoost {
  id                String   @id @default(uuid())
  mini_app_id       String
  boost_type        String
  price             Float
  duration_days     Int?
  started_at        DateTime @default(now())
  expires_at        DateTime
  status            String   @default("active")
  payment_reference String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  mini_app          MiniApp  @relation(fields: [mini_app_id], references: [id], onDelete: Cascade)

  @@index([mini_app_id])
  @@index([boost_type])
  @@index([status])
  @@index([expires_at])
  @@map("mini_app_boosts")
}

model MiniAppInstall {
  id             String    @id @default(uuid())
  mini_app_id    String
  user_id        String
  installed_at   DateTime  @default(now())
  last_used_at   DateTime?
  uninstalled_at DateTime?
  mini_app       MiniApp   @relation(fields: [mini_app_id], references: [id], onDelete: Cascade)
  user           User      @relation("MiniAppInstalls", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([mini_app_id, user_id])
  @@index([mini_app_id])
  @@index([user_id])
  @@index([installed_at])
  @@map("mini_app_installs")
}

model DeveloperRevenue {
  id                 String                @id @default(uuid())
  developer_id       String                @unique
  balance            Float                 @default(0)
  pending_balance    Float                 @default(0)
  total_earned       Float                 @default(0)
  total_withdrawn    Float                 @default(0)
  last_withdrawal_at DateTime?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt
  developer          User                  @relation("DeveloperRevenues", fields: [developer_id], references: [id], onDelete: Cascade)
  withdrawals        DeveloperWithdrawal[]

  @@index([developer_id])
  @@map("developer_revenues")
}

model DeveloperWithdrawal {
  id             String           @id @default(uuid())
  developer_id   String
  amount         Float
  fee            Float            @default(500)
  net_amount     Float
  payment_method String
  phone_number   String?
  bank_account   String?
  status         String           @default("pending")
  reference      String?
  processed_at   DateTime?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  revenue        DeveloperRevenue @relation(fields: [developer_id], references: [developer_id], onDelete: Cascade)

  @@index([developer_id])
  @@index([status])
  @@index([created_at])
  @@map("developer_withdrawals")
}

model Comment {
  id          String    @id @default(uuid())
  video_id    String
  user_id     String
  content     String
  /// URL du commentaire vocal (upload `/api/upload/audio`), optionnel
  audio_url   String?
  parent_id   String?
  user_name   String?
  user_avatar String?
  mention_ids String[]  @default([])
  is_pinned   Boolean   @default(false)
  created_at  DateTime  @default(now())
  parent      Comment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies     Comment[] @relation("CommentReplies")
  reactions   CommentReaction[]
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video       Video     @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([video_id])
  @@index([user_id])
  @@index([user_id], map: "idx_comments_user")
}

/// Phase 23 — une réaction par utilisateur et par commentaire.
model CommentReaction {
  id         String   @id @default(uuid())
  comment_id String
  user_id    String
  type       String   @default("like")
  created_at DateTime @default(now())
  comment    Comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, user_id])
  @@index([comment_id])
}

model Follow {
  id           String   @id @default(uuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())
  follower     User     @relation("Follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following    User     @relation("Following", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@index([follower_id])
  @@index([following_id])
}

/// Demande de suivi pour compte privé (CPO 2.2)
model FollowRequest {
  id           String   @id @default(uuid())
  requester_id String
  target_id    String
  status       String   @default("pending")
  created_at   DateTime @default(now())
  responded_at DateTime?
  requester    User     @relation("FollowRequestRequester", fields: [requester_id], references: [id], onDelete: Cascade)
  target       User     @relation("FollowRequestTarget", fields: [target_id], references: [id], onDelete: Cascade)

  @@unique([requester_id, target_id])
  @@index([requester_id])
  @@index([target_id])
  @@index([status])
}

model WonderRelation {
  id          String   @id @default(uuid())
  follower_id String
  creator_id  String
  status      String   @default("active")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  creator     User     @relation("WonderCreator", fields: [creator_id], references: [id], onDelete: Cascade)
  wonderer    User     @relation("Wonderer", fields: [follower_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, creator_id])
  @@index([follower_id])
  @@index([creator_id])
  @@index([status])
}

model Save {
  id            String          @id @default(uuid())
  user_id       String
  video_id      String
  collection_id String?
  created_at    DateTime        @default(now())
  user          User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video         Video           @relation(fields: [video_id], references: [id], onDelete: Cascade)
  collection    SaveCollection? @relation(fields: [collection_id], references: [id], onDelete: SetNull)

  @@unique([user_id, video_id])
  @@index([video_id])
  @@index([user_id])
  @@index([collection_id])
}

/// Phase 23 — dossiers « Mes sauvegardes » (privés).
model SaveCollection {
  id         String   @id @default(uuid())
  user_id    String
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  saves      Save[]

  @@index([user_id])
}

model ViewHistory {
  id            String   @id @default(uuid())
  user_id       String
  video_id      String
  completed     Boolean  @default(false)
  category      String?
  created_at    DateTime @default(now())
  watch_seconds Int?
  watch_percent Float?
  updated_at    DateTime @default(now()) @updatedAt
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video         Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([video_id])
  @@index([user_id, updated_at])
}

/// Comptage vues enterprise: 1 vue / 30 min / user|device / vidéo. Backend source de vérité.
model VideoView {
  id          String   @id @default(uuid())
  video_id    String
  viewer_key  String
  time_bucket Int
  created_at  DateTime @default(now())
  video       Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([video_id, viewer_key, time_bucket])
  @@index([video_id])
  @@index([video_id, time_bucket])
}

model Product {
  id                String             @id @default(uuid())
  name              String
  description       String
  price             Float
  stock             Int                @default(0)
  seller_id         String
  images            String[]
  category          String?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  brand             String?
  condition         String?
  currency          String?            @default("XOF")
  delivery_options  Json?
  status            String             @default("active")
  product_type      String?            @default("physical")
  subcategory       String?
  video_url         String?
  latitude          Float?
  longitude         Float?
  weight_kg         Float?
  negotiable_price  Boolean            @default(false)
  valid_until       DateTime?
  flash_sales       FlashSale[]
  inventory_logs    InventoryLog[]
  order_items       OrderItem[]
  order_reviews     OrderReview[]
  seller            User               @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  product_analytics ProductAnalytics[]
  promotions        ProductPromotion[]
  product_questions ProductQuestion[]
  variants          ProductVariant[]
  reviews           Review[]
  wishlist          Wishlist[]
  product_alerts    ProductAlert[]
  preorders         Preorder[]
  price_offers      ProductOffer[]
  auction           ProductAuction?
  group_buys        GroupBuy[]
  delivery_url      String?
  is_merchandising  Boolean   @default(false)
  is_preorder       Boolean   @default(false)
  preorder_available_at DateTime?
  live_products     LiveStreamProduct[]
  live_pinned       LivePinnedProduct[]

  @@index([status])
  @@index([seller_id, is_merchandising])
  @@index([seller_id, status])
  @@index([category, status])
  @@index([status, created_at])
  @@index([seller_id, status], map: "idx_products_seller_status")
}

/// CPO 6.38 — Alertes prix ou disponibilité (notification quand le prix baisse ou le produit revient en stock)
model ProductAlert {
  id          String   @id @default(uuid())
  product_id  String
  user_id     String
  alert_type  String   // 'price' | 'stock'
  target_price Float?  // pour price: notifier si prix <= target_price
  created_at  DateTime @default(now())
  notified_at DateTime?
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([product_id, user_id, alert_type])
  @@index([product_id])
  @@index([user_id])
  @@index([alert_type])
}

/// CPO 6.37 — Précommandes : réserver un produit pas encore disponible ; paiement à la sortie
model Preorder {
  id          String   @id @default(uuid())
  product_id  String
  user_id     String
  quantity    Int      @default(1)
  status      String   @default("reserved")   // reserved | cancelled
  reserved_at DateTime @default(now())
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([user_id])
  @@index([status])
}

/// CPO 6.36 — Négociation de prix : acheteur propose un prix, vendeur accepte ou refuse
model ProductOffer {
  id           String    @id @default(uuid())
  product_id   String
  buyer_id     String
  offered_price Float
  status       String    @default("pending")   // pending | accepted | declined
  seller_note  String?
  created_at   DateTime  @default(now())
  responded_at DateTime?
  product      Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  buyer        User      @relation(fields: [buyer_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([buyer_id])
  @@index([status])
}

/// CPO 6.35 — Enchères : mise aux enchères d'un produit
model ProductAuction {
  id               String    @id @default(uuid())
  product_id       String    @unique
  seller_id        String
  start_price      Float
  current_bid      Float
  current_bidder_id String?
  end_at           DateTime
  status           String    @default("open")   // open | closed
  created_at       DateTime  @default(now())
  product          Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  seller           User      @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  current_bidder   User?     @relation("AuctionBidder", fields: [current_bidder_id], references: [id], onDelete: SetNull)

  @@index([seller_id])
  @@index([status])
  @@index([end_at])
}

/// CPO 9.33 — Alertes prix voyage (destination / hôtel) : notification quand le prix baisse
model TravelPriceAlert {
  id             String    @id @default(uuid())
  user_id        String
  type           String             // flight | hotel
  origin         String?            // code aéroport ou ville (vol)
  destination    String
  target_price   Float
  check_in       DateTime?         // pour hôtel
  check_out      DateTime?
  notified_at    DateTime?
  created_at     DateTime  @default(now())
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([type, destination])
}

/// CPO 9.25 — Groupes d'achat : commander en groupe pour prix ou livraison
model GroupBuy {
  id           String    @id @default(uuid())
  product_id   String
  creator_id   String
  min_quantity Int       @default(2)
  status       String    @default("open")   // open | closed | fulfilled
  end_at       DateTime?
  created_at   DateTime  @default(now())
  product      Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  creator      User      @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  participants GroupBuyParticipant[]

  @@index([product_id])
  @@index([creator_id])
  @@index([status])
}

model GroupBuyParticipant {
  id          String   @id @default(uuid())
  group_buy_id String
  user_id     String
  quantity    Int      @default(1)
  joined_at   DateTime @default(now())
  group_buy   GroupBuy @relation(fields: [group_buy_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([group_buy_id, user_id])
  @@index([group_buy_id])
  @@index([user_id])
}

/// CPO 11.36 — A/B testing (admin) : expériences et affectation utilisateur
model Experiment {
  id          String    @id @default(uuid())
  key         String    @unique
  name        String
  description String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  variants    ExperimentVariant[]
  assignments UserExperimentAssignment[]
}

model ExperimentVariant {
  id            String     @id @default(uuid())
  experiment_id String
  variant_key   String     // e.g. control | variant_a
  traffic_pct   Int        @default(50)   // 0-100
  config        Json?      // payload optionnel pour le front
  experiment    Experiment @relation(fields: [experiment_id], references: [id], onDelete: Cascade)

  @@unique([experiment_id, variant_key])
  @@index([experiment_id])
}

model UserExperimentAssignment {
  id            String    @id @default(uuid())
  user_id       String
  experiment_id String
  variant_key   String
  assigned_at   DateTime  @default(now())
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  experiment    Experiment @relation(fields: [experiment_id], references: [id], onDelete: Cascade)

  @@unique([user_id, experiment_id])
  @@index([user_id])
  @@index([experiment_id])
}

/// CPO 9.22 — Co-voiturage : trajets proposés par des conducteurs
model RideShare {
  id               String    @id @default(uuid())
  driver_id        String
  origin           String
  destination      String
  departure_at     DateTime
  seats_available  Int       @default(4)
