  @@index([user_id, status])
  @@index([type, status])
  @@index([user_id, type, created_at])
}

model VideoTip {
  id               String       @id @default(uuid())
  video_id         String
  sender_id        String
  receiver_id      String // Le créateur de la vidéo
  amount           Float
  currency         String       @default("XOF")
  payment_method   String       @default("orange_money") // orange_money uniquement pour l'instant
  transaction_id   String? // Référence à la transaction
  message          String? // Message optionnel du donateur
  status           String       @default("pending") // pending, completed, failed
  afriwonder_fee   Float        @default(0) // Commission de la plateforme (10%)
