model PlaylistItem {
  id          String   @id @default(uuid())
  playlist_id String
  video_id    String
  position    Int
  added_at    DateTime @default(now())
  playlist    Playlist @relation(fields: [playlist_id], references: [id], onDelete: Cascade)
  video       Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([playlist_id, video_id])
  @@index([playlist_id])
  @@index([video_id])
}

model Music {
  id          String   @id @default(uuid())
  title       String
  artist      String
  album       String?
  duration    Int
  audio_url   String
  cover_url   String?
  genre       String?
  plays_count Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([artist])
  @@index([genre])
}

model Analytics {
  id           String   @id @default(uuid())
  user_id      String?
  entity_type  String
  entity_id    String
  metric_type  String
  metric_value Float
  date         DateTime @default(now())
  metadata     Json?

  @@index([user_id])
  @@index([entity_type])
  @@index([entity_id])
  @@index([date])
}

model SubscriptionTier {
  id            String         @id @default(uuid())
  creator_id    String
  name          String
  price         Float
  benefits      String[]
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  subscriptions Subscription[]

  @@index([creator_id])
  @@index([is_active])
}

model Payout {
  id             String    @id @default(uuid())
  creator_id     String
  amount         Float
  currency       String    @default("XOF")
  status         String    @default("pending")
  payment_method String
  processed_at   DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([creator_id])
  @@index([status])
  @@index([created_at])
}

model Campaign {
  id             String         @id @default(uuid())
  creator_id     String
  creator        User           @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  title          String
  description    String
  goal_amount    Float
  current_amount Float          @default(0)
  backers_count  Int            @default(0)
  end_date       DateTime
  status         String         @default("active")
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  kyc_verified   Boolean        @default(false)
  report_count   Int            @default(0)
  fraud_flag     Boolean        @default(false)
  milestones     Json?
  /// Catégorie affichage (agriculture, education, etc.)
  category       String?
  /// URL absolue ou chemin CDN — couverture campagne
  cover_image    String?
  /// Paliers de récompenses saisis à la création (JSON, mobile + admin)
  rewards_data   Json?
  contributions  Contribution[]
  escrow_wallet  Wallet?        @relation("CampaignEscrow")
  cf_updates     CrowdfundingUpdate[]
  cf_comments    CrowdfundingComment[]

  @@index([creator_id])
  @@index([status])
  @@index([end_date])
  @@index([fraud_flag])
  @@index([category])
}

/// Actualités publiées par le porteur (fil d’updates).
model CrowdfundingUpdate {
  id          String   @id @default(uuid())
  campaign_id String
  campaign    Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  title       String
  content     String
  image_url   String?
  created_at  DateTime @default(now())

  @@index([campaign_id])
  @@map("cf_campaign_updates")
}

/// Commentaires / discussion sous une campagne (utilisateurs connectés).
model CrowdfundingComment {
  id          String   @id @default(uuid())
  campaign_id String
  campaign    Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content     String
  parent_id   String?
  parent      CrowdfundingComment?  @relation("CfCommentThread", fields: [parent_id], references: [id], onDelete: SetNull)
  replies     CrowdfundingComment[] @relation("CfCommentThread")
  created_at  DateTime @default(now())

  @@index([campaign_id])
  @@index([user_id])
  @@map("cf_campaign_comments")
}

model Contribution {
  id                 String    @id @default(uuid())
  campaign_id        String
  contributor_id     String
  amount             Float
  reward_tier        String?
  created_at         DateTime  @default(now())
  status             String    @default("pending")
  escrow_released_at DateTime?
  campaign           Campaign  @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@index([campaign_id])
  @@index([contributor_id])
  @@index([status])
}

model LoanRequest {
  id                      String                  @id @default(uuid())
  borrower_id             String
  purpose                 String
  interest_rate           Float
  status                  String                  @default("active")
  approved_at             DateTime?
  funded_at               DateTime?
  created_at              DateTime                @default(now())
  updated_at              DateTime                @updatedAt
  amount_requested        Float
  current_amount          Float                   @default(0)
  repayment_period_months Int
  business_plan           String?
  credit_score            Float?
  risk_level              String?
  deadline                DateTime?
  agreement               LoanAgreement?
  repayments              LoanRepayment[]
  borrower                User                    @relation(fields: [borrower_id], references: [id], onDelete: Cascade)
  contributions           MicroloanContribution[]

  @@index([borrower_id])
  @@index([status])
  @@index([deadline])
}

model LoanAgreement {
  id                 String      @id @default(uuid())
  loan_id            String      @unique
  borrower_signature String?
  lender_signature   String?
  contract_pdf_url   String?
  created_at         DateTime    @default(now())
  loan_request       LoanRequest @relation(fields: [loan_id], references: [id], onDelete: Cascade)

  @@index([loan_id])
}

model LoanRepayment {
  id             String      @id @default(uuid())
  loan_id        String
  due_date       DateTime
  amount_due     Float
  amount_paid    Float       @default(0)
  status         String      @default("pending")
  penalty_amount Float       @default(0)
  paid_at        DateTime?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  loan_request   LoanRequest @relation(fields: [loan_id], references: [id], onDelete: Cascade)

  @@index([loan_id])
  @@index([due_date])
  @@index([status])
}

model MicroloanContribution {
  id           String      @id @default(uuid())
  loan_id      String
  lender_id    String
  amount       Float
  created_at   DateTime    @default(now())
  loan_request LoanRequest @relation(fields: [loan_id], references: [id], onDelete: Cascade)

  @@index([loan_id])
  @@index([lender_id])
}

model Job {
  id              String           @id @default(uuid())
  employer_id     String
  title           String
  description     String
  location        String?
  salary_min      Float?
  salary_max      Float?
  job_type        String
  category        String?
  status          String           @default("open")
  expires_at      DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  salary_currency String           @default("XOF")
  country         String?
  views_count     Int              @default(0)
  is_premium      Boolean          @default(false)
  is_urgent       Boolean          @default(false)
  employer        User             @relation(fields: [employer_id], references: [id], onDelete: Cascade)
  applications    JobApplication[]
  saved_by        SavedJob[]

  @@index([employer_id])
  @@index([status])
  @@index([category])
  @@index([country])
}

model JobApplication {
  id           String   @id @default(uuid())
  job_id       String
  applicant_id String
  cover_letter String?
  resume_url   String?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  applicant    User     @relation(fields: [applicant_id], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@unique([job_id, applicant_id])
  @@index([job_id])
  @@index([applicant_id])
}

model CandidateProfile {
  id            String   @id @default(uuid())
  user_id       String   @unique
  cv_url        String?
  portfolio_url String?
  skills        Json?
  experience    Json?
  education     Json?
  availability  String?
  phone         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model CompanyProfile {
  id              String   @id @default(uuid())
  user_id         String   @unique
  company_name    String?
  description     String?
  logo_url        String?
  documents_legal String?
  is_verified     Boolean  @default(false)
  rating_avg      Float    @default(0)
  rating_count    Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_verified])
}

model CompanyRating {
  id           String   @id @default(uuid())
  from_user_id String
  to_user_id   String
  job_id       String
  rating       Int
  comment      String?
  created_at   DateTime @default(now())
  from_user    User     @relation("CompanyRatingsGiven", fields: [from_user_id], references: [id], onDelete: Cascade)
  to_user      User     @relation("CompanyRatingsReceived", fields: [to_user_id], references: [id], onDelete: Cascade)

  @@unique([from_user_id, to_user_id, job_id])
  @@index([to_user_id])
}

model CandidateRating {
  id           String   @id @default(uuid())
  from_user_id String
  to_user_id   String
  job_id       String
  rating       Int
  comment      String?
  created_at   DateTime @default(now())
  from_user    User     @relation("CandidateRatingsGiven", fields: [from_user_id], references: [id], onDelete: Cascade)
  to_user      User     @relation("CandidateRatingsReceived", fields: [to_user_id], references: [id], onDelete: Cascade)

  @@unique([from_user_id, to_user_id, job_id])
  @@index([to_user_id])
}

model SavedJob {
  id         String   @id @default(uuid())
  job_id     String
  user_id    String
  created_at DateTime @default(now())
  job        Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([job_id, user_id])
  @@index([job_id])
  @@index([user_id])
}

model ServiceProvider {
  id                 String                  @id @default(uuid())
  user_id            String                  @unique
  status             String                  @default("pending")
  is_verified        Boolean                 @default(false)
  verification_badge String?
  kyc_status         String                  @default("pending")
  kyc_document_url   String?
  kyc_selfie_url     String?
  service_categories String[]                @default([])
  service_radius_km  Float                   @default(10)
  location_type      String                  @default("both")
  average_rating     Float                   @default(0)
  total_bookings     Int                     @default(0)
  total_earnings     Float                   @default(0)
  payout_method      String?
  payout_account     String?
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  phone              String?
  whatsapp           String?
  email              String?
  address            String?
  city               String?
  country            String?
  bio                String?
  services           Service[]
  availabilities     ServiceAvailability[]
  bookings           ServiceBooking[]        @relation("Provider")
  disputes           ServiceDispute[]
  payouts            ServicePayout[]
  user               User                    @relation("ServiceProvider", fields: [user_id], references: [id], onDelete: Cascade)
  reviews            ServiceReview[]
  unavailabilities   ServiceUnavailability[]

  @@index([user_id])
  @@index([status])
  @@index([is_verified])
  @@index([kyc_status])
  @@index([service_categories])
}

model ServiceCategory {
  id          String            @id @default(uuid())
  name        String            @unique
  slug        String            @unique
  description String?
  icon_url    String?
  parent_id   String?
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  services    Service[]
  parent      ServiceCategory?  @relation("CategoryParent", fields: [parent_id], references: [id])
  children    ServiceCategory[] @relation("CategoryParent")

  @@index([slug])
  @@index([parent_id])
  @@index([is_active])
}

model Service {
  id             String           @id @default(uuid())
  provider_id    String
  title          String
  description    String
  price          Float
  category       String?
  location       String?
  is_available   Boolean          @default(true)
  rating         Float            @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  category_id    String?
  currency       String           @default("XOF")
  duration       Int?
  location_type  String           @default("both")
  total_bookings Int              @default(0)
  travel_fee     Float            @default(0)
  category_ref   ServiceCategory? @relation(fields: [category_id], references: [id])
  provider       ServiceProvider  @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  bookings       ServiceBooking[]
  reviews        ServiceReview[]

  @@index([provider_id])
  @@index([category])
  @@index([category_id])
  @@index([is_available])
  @@index([location_type])
}

model ServiceBooking {
  id                     String          @id @default(uuid())
  service_id             String
  customer_id            String
  provider_id            String
  status                 String          @default("pending")
  booking_date           DateTime
  booking_time           String
  duration               Int
  location_type          String
  customer_address_id    String?
  provider_address_id    String?
  total_price            Float
  platform_fee           Float
  provider_earnings      Float
  payment_status         String          @default("pending")
  payment_method         String?
  payment_transaction_id String?
  deposit_amount         Float           @default(0)
  deposit_paid           Boolean         @default(false)
  notes                  String?
  cancellation_reason    String?
  cancelled_by           String?
  confirmed_at           DateTime?
  started_at             DateTime?
  completed_at           DateTime?
  cancelled_at           DateTime?
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  customer_email         String?
  customer_name          String?
  customer_phone         String?
  customer_address       Address?        @relation("BookingCustomerAddress", fields: [customer_address_id], references: [id])
  customer               User            @relation("BookingCustomer", fields: [customer_id], references: [id], onDelete: Cascade)
  provider_address       Address?        @relation("BookingProviderAddress", fields: [provider_address_id], references: [id])
  provider               ServiceProvider @relation("Provider", fields: [provider_id], references: [id], onDelete: Cascade)
  service                Service         @relation(fields: [service_id], references: [id], onDelete: Cascade)
  dispute                ServiceDispute?
  review                 ServiceReview?

  @@index([service_id])
  @@index([customer_id])
  @@index([provider_id])
  @@index([status])
  @@index([booking_date])
  @@index([payment_status])
  @@index([customer_id, status])
  @@index([provider_id, status])
  @@index([customer_id, status], map: "idx_bookings_customer_status")
}

model ServiceAvailability {
  id            String          @id @default(uuid())
  provider_id   String
  day_of_week   Int
  start_time    String
  end_time      String
  is_available  Boolean         @default(true)
  is_recurring  Boolean         @default(true)
  specific_date DateTime?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  provider      ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([provider_id])
  @@index([day_of_week])
  @@index([specific_date])
  @@index([provider_id, day_of_week])
}

model ServiceUnavailability {
  id          String          @id @default(uuid())
  provider_id String
  start_date  DateTime
  end_date    DateTime
  reason      String
  notes       String?
  created_at  DateTime        @default(now())
  provider    ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([provider_id])
  @@index([start_date])
  @@index([end_date])
  @@index([provider_id, start_date, end_date])
}

model ServiceReview {
  id            String          @id @default(uuid())
  booking_id    String          @unique
  service_id    String
  provider_id   String
  customer_id   String
  rating        Int
  title         String?
  content       String
  photos        String[]        @default([])
  is_verified   Boolean         @default(false)
  helpful_count Int             @default(0)
  status        String          @default("approved")
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  booking       ServiceBooking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  customer      User            @relation("ServiceReviewCustomer", fields: [customer_id], references: [id], onDelete: Cascade)
  provider      ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  service       Service         @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@index([service_id])
  @@index([provider_id])
  @@index([customer_id])
  @@index([rating])
  @@index([status])
  @@index([service_id, status])
  @@index([provider_id, rating])
}

model ServiceDispute {
  id            String          @id @default(uuid())
  booking_id    String          @unique
  reporter_id   String
  reporter_type String
  reason        String
  description   String?
  evidence      String[]        @default([])
  status        String          @default("pending")
  resolution    String?
  resolved_by   String?
  resolved_at   DateTime?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  provider_id   String
  booking       ServiceBooking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  provider      ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([booking_id])
  @@index([reporter_id])
  @@index([provider_id])
  @@index([status])
  @@index([reporter_id, status])
}

model ServicePayout {
  id                String          @id @default(uuid())
  provider_id       String
  amount            Float
  currency          String          @default("XOF")
  commission_rate   Float
  commission_amount Float
  net_amount        Float
  status            String          @default("pending")
  payout_method     String
  payout_account    String
  booking_ids       String[]        @default([])
  processed_at      DateTime?
  completed_at      DateTime?
  failure_reason    String?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  provider          ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([provider_id])
  @@index([status])
  @@index([created_at])
  @@index([provider_id, status])
}

model Event {
  id                String                 @id @default(uuid())
  organizer_id      String
  title             String
  description       String?
  location          String?
  start_date        DateTime
  end_date          DateTime
  price             Float?                 @default(0)
  category          String?
  attendees_count   Int                    @default(0)
  created_at        DateTime               @default(now())
  updated_at        DateTime               @updatedAt
  capacity          Int?
  currency          String                 @default("XOF")
  event_type        String                 @default("physical")
  faq               Json?
  image             String?
  is_featured       Boolean                @default(false)
  is_free           Boolean                @default(true)
  latitude          Float?
  longitude         Float?
  organizer_name    String?
  platform_fee_pct  Float?                 @default(10)
  refund_policy     String?
  replay_url        String?
  status            String                 @default("draft")
  virtual_url       String?
  speakers          Json?
  featured_until    DateTime?
  sponsors          Json?
