generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String                  @id @default(uuid())
  email                     String                  @unique
  username                  String                  @unique
  password_hash             String
  full_name                 String?
  profile_image             String?
  country                   String?                 // Pays pour leaderboard / profil
  role                      String                  @default("user")
  is_verified               Boolean                 @default(false)
  account_suspended         Boolean                 @default(false)
  suspended_at              DateTime?
  suspended_reason          String?                 // fraud, abuse, legal, user_request
  created_at                DateTime                @default(now())
  updated_at                DateTime                @updatedAt
  addresses                 Address[]
  cart                      Cart?
  comments                  Comment[]
  follows                   Follow[]                @relation("Follower")
  following                 Follow[]                @relation("Following")
  likes                     Like[]
  live_streams              LiveStream[]
  live_viewers               LiveViewer[]
  live_moderator_of          LiveModerator[]
  live_likes                 LiveLike[]
  live_top_donors            LiveTopDonor[]
  creator_level              CreatorLevel?
  moderation_reports        Moderation[]            @relation("ModerationReporter")
  notifications             Notification[]
  notification_logs         NotificationLog[]
  notification_preference   NotificationPreference?
  orders                    Order[]
  order_reviews             OrderReview[]           @relation("OrderReviewUser")
  products                  Product[]
  reports                   Report[]                @relation("Reporter")
  reviews                   Review[]
  saves                     Save[]
  subscriptions             Subscription[]
  transactions              Transaction[]
  video_tips_sent           VideoTip[]              @relation("TipSender")
  video_tips_received       VideoTip[]              @relation("TipReceiver")
  user_badges               UserBadge[]
  user_points               UserPoints?
  videos                    Video[]
  view_history              ViewHistory[]
  wallets                   Wallet[]
  wallet_security           WalletSecurity?
  seller_wallet             SellerWallet?
  withdrawals               Withdrawal[]
  wishlist                  Wishlist[]
  seller_profile            SellerProfile?
  seller_reviews_received   SellerReview[]          @relation("SellerReviewed")
  seller_reviews_given      SellerReview[]          @relation("SellerReviewAuthor")
  support_tickets           SupportTicket[]
  support_messages          SupportMessage[]
  enrollments               Enrollment[]
  certificates              Certificate[]
  courses_created          Course[]
  course_reviews            CourseReview[]
  course_wishlist           CourseWishlist[]
  user_level                UserLevel?
  conversations_user1       Conversation[]          @relation("User1")
  conversations_user2       Conversation[]          @relation("User2")
  stories                   Story[]
  playlists                 Playlist[]
  community_members         CommunityMember[]
  communities_created       Community[]
  referrals_sent            Referral[]              @relation("Referrer")
  referrals_received        Referral[]              @relation("Referred")
  user_verification         UserVerification?
  service_provider          ServiceProvider?        @relation("ServiceProvider")
  service_bookings_customer ServiceBooking[]        @relation("BookingCustomer")
  service_reviews           ServiceReview[]         @relation("ServiceReviewCustomer")
  events_organized          Event[]
  event_tickets             EventTicket[]
  event_attendances         EventAttendance[]
  event_payments            EventPayment[]
  event_likes               EventLike[]
  event_comments            EventComment[]
  event_featured_payments   EventFeaturedPayment[]
  event_chat_messages       EventChatMessage[]
  news_articles_authored    NewsArticle[]
  article_views             ArticleView[]
  article_likes             ArticleLike[]
  article_comments          ArticleComment[]
  user_news_preference      UserNewsPreference?
  news_premium_subscriptions NewsPremiumSubscription[]
  presence                  UserPresence?
  blocked_by                UserBlock[]             @relation("Blocked")
  blocking                  UserBlock[]             @relation("Blocker")
  messages_sent             Message[]
  message_reports           MessageReport[]
  loan_requests_borrowed     LoanRequest[]
  civic_petitions_created   CivicPetition[]
  jobs_created               Job[]
  job_applications           JobApplication[]
  candidate_profile          CandidateProfile?
  company_profile            CompanyProfile?
  petition_comments          PetitionComment[]
  petition_comment_likes     PetitionCommentLike[]
  company_ratings_received   CompanyRating[]   @relation("CompanyRatingsReceived")
  company_ratings_given     CompanyRating[]   @relation("CompanyRatingsGiven")
  candidate_ratings_received CandidateRating[] @relation("CandidateRatingsReceived")
  candidate_ratings_given   CandidateRating[] @relation("CandidateRatingsGiven")
  saved_jobs                 SavedJob[]
  saved_petitions            SavedPetition[]
  petition_signatures        PetitionSignature[]   @relation("PetitionSigner")
  coupons_created            Coupon[]
  user_loyalty_entries       UserLoyalty[]
  loyalty_program            LoyaltyProgram?
  // Legal & Security Relations
  legal_acceptances          UserLegalAcceptance[]
  cookie_preferences         UserCookiePreference?
  data_export_requests       DataExportRequest[]
  account_deletion_requests  AccountDeletionRequest[]
  security_logs              SecurityLog[]
  two_factor_auth            User2FA?
  admin_audit_logs           AdminAuditLog[]
  suspicious_activity_alerts SuspiciousActivityAlert[]
  // Ride / Transport
  rides_as_passenger        Ride[]                 @relation("RidePassenger")
  rides_as_driver           Ride[]                 @relation("RideDriver")
  // Driver profile (user_id on Driver)
  driver_profile            Driver?
  // Restaurant owner
  restaurants_owned         Restaurant[]
  // Food orders (customer + delivery person)
  food_orders_customer      FoodOrder[]            @relation("FoodOrderCustomer")
  food_orders_delivery      FoodOrder[]            @relation("FoodOrderDelivery")
  // Airtime & Bills
  airtime_recharges         AirtimeRecharge[]
  bill_payments             BillPayment[]
  // Tickets
  tickets                   Ticket[]
  // Health: Doctor profile + Appointments
  doctor_profile            Doctor?
  appointments_as_patient   Appointment[]          @relation("AppointmentPatient")
  // Pharmacy owner
  pharmacies_owned          Pharmacy[]
  // Property owner
  properties_owned          Property[]
  // Insurance
  insurance_policies        InsurancePolicy[]
  insurance_claims           InsuranceClaim[]
  // Property visit requests
  property_visit_requests   PropertyVisitRequest[]
}

model Video {
  id                    String                @id @default(uuid())
  title                 String
  description           String?
  video_url             String
  thumbnail_url         String?
  creator_id            String
  visibility            String                @default("public")
  category              String?
  hashtags              Json? // Array of hashtag strings
  music_title           String? // Music title
  views                 Int                   @default(0)
  likes                 Int                   @default(0)
  comments_count        Int                   @default(0)
  shares                Int                   @default(0)
  saves                 Int                   @default(0)
  duration              Int?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  collaborator_revenues CollaboratorRevenue[]
  video_comments        Comment[]
  video_likes           Like[]
  video_saves           Save[]
  video_tips            VideoTip[]
  creator               User                  @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  analytics             VideoAnalytics[]
  view_history          ViewHistory[]
  playlist_items        PlaylistItem[]

  @@index([creator_id, created_at])
  @@index([visibility, created_at])
  @@index([category])
}

model Like {
  id         String   @id @default(uuid())
  user_id    String
  video_id   String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id])
  @@index([video_id])
  @@index([user_id])
}

model Comment {
  id          String    @id @default(uuid())
  video_id    String
  user_id     String
  content     String
  parent_id   String?
  user_name   String?
  user_avatar String?
  created_at  DateTime  @default(now())
  parent      Comment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies     Comment[] @relation("CommentReplies")
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video       Video     @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([video_id])
  @@index([user_id])
}

model Follow {
  id           String   @id @default(uuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())
  follower     User     @relation("Follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following    User     @relation("Following", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@index([follower_id])
  @@index([following_id])
}

model Save {
  id         String   @id @default(uuid())
  user_id    String
  video_id   String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id])
  @@index([video_id])
  @@index([user_id])
}

model ViewHistory {
  id         String   @id @default(uuid())
  user_id    String
  video_id   String
  completed  Boolean  @default(false)
  category   String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([video_id])
}

model Product {
  id               String             @id @default(uuid())
  name             String
  description      String
  price            Float
  stock            Int                @default(0)
  seller_id        String
  images           String[]
  category         String?
  subcategory      String? // sous-catégorie
  product_type     String?            @default("physical") // physical | digital | service
  status           String             @default("active") // draft | active | suspended
  currency         String?            @default("XOF")
  brand            String?
  condition        String? // new | used | refurbished
  delivery_options Json? // ["local", "international", "pickup", "point_relais"]
  video_url        String? // Vidéo produit (une URL)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  inventory_logs   InventoryLog[]
  order_items      OrderItem[]
  order_reviews    OrderReview[]
  seller           User               @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  reviews          Review[]
  wishlist         Wishlist[]
  variants         ProductVariant[]
  promotions       ProductPromotion[]
  flash_sales      FlashSale[]
  product_analytics ProductAnalytics[]

  @@index([status])
  @@index([seller_id, status])
  @@index([category, status])
  @@index([status, created_at])
}

model Order {
  id                      String         @id @default(uuid())
  user_id                 String
  seller_id               String? // Vendeur principal (pour optimisation)
  status                  String         @default("pending") // pending, pending_payment, paid, processing, preparing, in_transit, delivered, completed, cancelled, refunded
  currency                String         @default("XOF")
  display_currency        String? // Devise d'affichage
  exchange_rate           Float? // Taux de change au moment de la commande
  subtotal_amount         Float // Sous-total produits
  shipping_amount         Float          @default(0) // Frais livraison
  tax_amount              Float          @default(0) // Taxes
  total_amount            Float
  payment_status          String         @default("pending") // pending, paid, failed, refunded, escrow, released
  payment_method          String? // orange_money, mtn_money, wave, flutterwave, paystack, card, cod, wallet
  transaction_id          String? // ID transaction paiement
  provider                String? // Provider paiement utilisé
  shipping_address        String? // Adresse livraison (texte)
  billing_address         String? // Adresse facturation
  tracking_number         String? // Numéro de suivi
  carrier                 String? // Transporteur
  estimated_delivery_date DateTime? // Date livraison estimée
  actual_delivery_date    DateTime? // Date livraison réelle
  escrow_status           String         @default("pending") // pending, held, released, refunded
  dispute_status          String? // open, investigating, resolved, rejected
  customer_notes          String? // Notes client
  source                  String         @default("marketplace") // marketplace | live (Acheté pendant live)
  live_id                 String? // ID du live si source = live
  logistics_fee           Float? // Commission logistique plateforme
  insurance_amount        Float? // Assurance livraison payante
  priority_fee            Float? // Traitement prioritaire payant
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt
  paid_at                 DateTime?
  shipped_at              DateTime?
  delivered_at            DateTime?
  user                    User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items                   OrderItem[]
  shipping                Shipping?
  refunds                 Refund[]
  payments                OrderPayment[]
  disputes                Dispute[]
  reviews                 OrderReview[]
  invoice                 OrderInvoice?

  @@index([user_id])
  @@index([seller_id])
  @@index([status])
  @@index([payment_status])
  @@index([user_id, status])
  @@index([seller_id, status])
  @@index([status, created_at])
  @@index([tracking_number])
  @@index([payment_status, status])
}

model OrderItem {
  id               String       @id @default(uuid())
  order_id         String
  product_id       String
  quantity         Int
  unit_price       Float // Prix unitaire au moment de la commande
  product_snapshot Json? // Snapshot produit: { name, images, description, seller_name, etc. }
  variant          Json? // Variantes: { size, color, etc. }
  order            Order        @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product          Product      @relation(fields: [product_id], references: [id], onDelete: Cascade)
  review           OrderReview?

  @@index([order_id])
  @@index([product_id])
}

model Notification {
  id             String   @id @default(uuid())
  user_id        String
  type           String
  title          String
  message        String
  is_read        Boolean  @default(false)
  reference_id   String?
  reference_type String?
  created_at     DateTime @default(now())
  action_url     String?
  from_user_id   String?
  from_user_name String?
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
}

model UserPoints {
  id                    String    @id @default(uuid())
  user_id               String    @unique
  total_points          Int       @default(0)
  lifetime_points       Int       @default(0)
  level                 Int       @default(1)
  current_level_points  Int       @default(0)
  points_for_next_level Int       @default(1000)
  points_balance        Float     @default(0)
  badges_count          Int       @default(0)
  last_points_awarded   DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([total_points])
}

model UserBadge {
  id                String   @id @default(uuid())
  user_id           String
  badge_id          String
  badge_name        String
  badge_icon        String
  badge_description String?
  category          String?
  earned_date       DateTime @default(now())
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, badge_id])
  @@index([user_id])
}

model LiveStream {
  id                  String          @id @default(uuid())
  creator_id          String
  creator_name        String
  title               String
  description         String?
  category            String?
  stream_url          String
  stream_token        String?         // Token sécurisé Agora/LiveKit/IVS
  stream_key          String?         // Clé RTMP (AWS IVS / Mux / Agora)
  rtmp_url            String?         // URL d’ingestion RTMP
  playback_url        String?         // URL de lecture HLS/DASH
  thumbnail_url       String?
  replay_url          String?
  status              String          @default("live") // scheduled | live | ended
  viewers_count       Int             @default(0)
  peak_viewers        Int             @default(0)
  total_watch_time    Int?            // Somme des temps de visionnage (secondes)
  started_at          DateTime        @default(now())
  ended_at            DateTime?
  duration_minutes    Int?
  total_gifts_amount  Float           @default(0)
  total_messages      Int             @default(0)
  total_likes        Int             @default(0)
  is_featured         Boolean         @default(false)
  region              String?         // Pays/région (SN, CI, FR…)
  language            String?        // fr, en, ar…
  room_id             String          @unique
  scheduled_at        DateTime?       // Si status = scheduled
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  chat_messages       LiveChat[]
  gifts               LiveGift[]
  bans                LiveStreamBan[]
  viewers             LiveViewer[]
  moderation_settings LiveModerationSettings?
  moderators          LiveModerator[]
  likes               LiveLike[]
  top_donors          LiveTopDonor[]
  analytics           LiveAnalytics?
  creator             User            @relation(fields: [creator_id], references: [id], onDelete: Cascade)

  @@index([creator_id])
  @@index([status])
  @@index([is_featured])
  @@index([room_id])
  @@index([region])
  @@index([category])
}

model LiveViewer {
  id             String     @id @default(uuid())
  live_id        String
  user_id        String
  session_id     String
  joined_at      DateTime   @default(now())
  left_at        DateTime?
  watch_duration Int?       // Temps de visionnage en secondes
  country        String?    // Pays du viewer (analytics)
  is_active      Boolean    @default(true)
  last_seen_at   DateTime   @default(now())
  live_stream    LiveStream @relation(fields: [live_id], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([live_id, user_id, session_id])
  @@index([live_id])
  @@index([user_id])
  @@index([is_active])
}

model LiveModerationSettings {
  id                String     @id @default(uuid())
  live_id           String     @unique
  slow_mode_seconds Int        @default(0)
  comments_enabled  Boolean    @default(true)
  followers_only    Boolean    @default(false)
  banned_words      Json?      // string[]
  live_stream       LiveStream @relation(fields: [live_id], references: [id], onDelete: Cascade)

  @@index([live_id])
}

model LiveModerator {
  id         String     @id @default(uuid())
  live_id    String
  user_id    String
  created_at DateTime   @default(now())
  live_stream LiveStream @relation(fields: [live_id], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([live_id, user_id])
  @@index([live_id])
  @@index([user_id])
}

model LiveLike {
  id         String     @id @default(uuid())
  live_id    String
  user_id    String
  created_at DateTime   @default(now())
  live_stream LiveStream @relation(fields: [live_id], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([live_id])
  @@index([user_id])
}

model LiveAnalytics {
  id                      String     @id @default(uuid())
  live_id                 String     @unique
  total_viewers           Int        @default(0)
  peak_viewers            Int        @default(0)
  unique_viewers          Int        @default(0)
  total_gifts_value       Float      @default(0)
  total_messages          Int        @default(0)
  total_likes             Int        @default(0)
  average_watch_time_seconds Int?
  duration_seconds        Int?
  viewer_countries        Json?      // { "SN": 120, "CI": 45, "FR": 30 }
  retention_buckets       Json?      // [ { "min": 0, "max": 60, "count": 50 }, ... ]
  computed_at             DateTime   @default(now())
  live_stream             LiveStream @relation(fields: [live_id], references: [id], onDelete: Cascade)

  @@index([live_id])
}

model LiveTopDonor {
  id           String     @id @default(uuid())
  live_id      String
  user_id      String
  total_amount Float
  rank         Int
  created_at   DateTime   @default(now())
  live_stream  LiveStream @relation(fields: [live_id], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([live_id, user_id])
  @@index([live_id])
  @@index([user_id])
}

model CreatorLevel {
  id              String   @id @default(uuid())
  user_id         String   @unique
  level           Int      @default(1)
  total_earnings  Float    @default(0)
  total_streams   Int      @default(0)
  updated_at      DateTime @updatedAt
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model LiveGift {
  id                  String     @id @default(uuid())
  live_id             String
  sender_id           String
  sender_name         String
  sender_avatar       String?
  creator_id          String
  gift_id             String
  gift_name           String
  gift_icon           String
  amount              Float
  quantity            Int        @default(1)
  total_amount        Float
  creator_earnings    Float
  platform_commission Float
  message             String?
  created_at          DateTime   @default(now())
  live_stream         LiveStream @relation(fields: [live_id], references: [id], onDelete: Cascade)

  @@index([live_id])
  @@index([sender_id])
  @@index([creator_id])
}

model LiveChat {
  id            String     @id @default(uuid())
  live_id       String
  sender_id     String
  sender_name   String
  sender_avatar String?
  sender_role   String     @default("viewer") // viewer | moderator | creator
  message       String
  message_type  String     @default("text")   // text | gift | system
  is_deleted    Boolean    @default(false)
  is_pinned     Boolean    @default(false)
  is_moderated  Boolean    @default(false)   // Modéré (caché ou averti)
  created_date  DateTime   @default(now())
  live_stream   LiveStream @relation(fields: [live_id], references: [id], onDelete: Cascade)

  @@index([live_id])
  @@index([sender_id])
  @@index([created_date])
  @@index([is_pinned])
}

model Wallet {
  id                  String        @id @default(uuid())
  user_id             String
  wallet_type         String        @default("user") // user | campaign_escrow
  currency            String        @default("XOF")
  balance             Float         @default(0) // DÉPRÉCIÉ: utiliser available_balance; gardé pour compat
  available_balance   Float         @default(0)
  pending_balance     Float         @default(0)
  locked_balance      Float         @default(0)
  total_earnings      Float         @default(0)
  total_payouts       Float         @default(0)
  status              String        @default("active") // active | frozen | closed
  campaign_id         String?       // Si wallet_type = campaign_escrow
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  user                User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ledger_entries      LedgerEntry[]
  campaign_escrow     Campaign?     @relation("CampaignEscrow", fields: [campaign_id], references: [id], onDelete: SetNull)

  @@unique([campaign_id]) // un escrow wallet par campagne (campaign_id nullable pour wallets user)
  @@index([user_id])
  @@index([wallet_type])
  @@index([campaign_id])
  @@index([user_id, wallet_type])
}

// Double écriture: ne jamais modifier balance directement. Toutes les opérations passent par LedgerEntry.
model LedgerEntry {
  id             String   @id @default(uuid())
  wallet_id      String
  type           String   // credit | debit
  amount         Float
  reference_id   String?
  reference_type String?  // order | contribution | withdrawal | refund | tip | campaign | loan | etc.
  description    String?
  balance_before Float
  balance_after  Float
  created_at     DateTime @default(now())
  wallet         Wallet   @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([wallet_id])
  @@index([reference_id, reference_type])
  @@index([created_at])
}

model WalletSecurity {
  id                    String    @id @default(uuid())
  user_id               String    @unique
  pin_hash              String?   // Hash du PIN wallet (optionnel)
  withdrawal_daily_limit Float?   // Limite retrait quotidien
  last_withdrawal_at    DateTime?
  withdrawal_count_today Int       @default(0)
  two_fa_required_for_withdrawal Boolean @default(true)
  is_blocked            Boolean   @default(false)
  blocked_reason        String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model Transaction {
  id             String     @id @default(uuid())
  user_id        String
  type           String
  amount         Float
  currency       String     @default("XOF")
  status         String     @default("pending")
  description    String?
  reference_id   String?
  payment_method String? // orange_money, stripe, wallet, etc.
  phone_number   String? // Pour Orange Money
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  user           User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
