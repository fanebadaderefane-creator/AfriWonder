/// Envelope chiffrée E2E stockée pour livraison/sync multi-appareils
model EncryptedMessageEnvelope {
  id                 String   @id @default(uuid())
  conversation_id    String?
  group_id           String?
  message_id         String?
  group_message_id   String?
  sender_user_id     String
  sender_device_id   String
  recipient_user_id  String?
  recipient_device_id String?
  ciphertext         String
  iv                 String
  aad                String?
  cipher_algo        String   @default("xchacha20poly1305")
  message_type       String   @default("text")
  client_message_id  String?
  created_at         DateTime @default(now())

  @@index([conversation_id, created_at])
  @@index([group_id, created_at])
  @@index([message_id])
  @@index([group_message_id])
  @@index([recipient_user_id, recipient_device_id, created_at])
  @@index([sender_user_id, sender_device_id, created_at])
  @@unique([sender_user_id, sender_device_id, client_message_id, recipient_user_id, recipient_device_id], map: "uniq_e2ee_envelope_idempotency")
}

