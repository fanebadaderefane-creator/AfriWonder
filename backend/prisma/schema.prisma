model Conversation {
  id                 String    @id @default(uuid())
  user1_id           String
  user2_id           String
  last_message_at    DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  last_message_id    String?
  last_message_text  String?
  unread_count_map   Json?
  is_group           Boolean   @default(false)
  group_name         String?
  group_avatar       String?
  draft_content      Json?
  is_archived_user1  Boolean   @default(false)
  is_archived_user2  Boolean   @default(false)
  muted_user1        Boolean   @default(false)
  muted_user2        Boolean   @default(false)
  /// Effacer l’historique « pour moi » — ne montrer que les messages après cette date (utilisateur 1 / 2).
  cleared_before_at_user1 DateTime?
  cleared_before_at_user2 DateTime?
  /// DM type « demande de message » (TikTok) : cet utilisateur doit accepter avant réponse libre ; null = pas d’attente.
  dm_request_pending_for_user_id String?
  /// Utilisateur qui a initié la conversation (max 3 messages tant que la demande est en attente).
  dm_request_initiator_id        String?
  pinned_message_id  String?   @unique // CPO 4.23 — message épinglé en haut (1-1) ; @unique requis pour relation 1-1
  user1              User      @relation("User1", fields: [user1_id], references: [id], onDelete: Cascade)
  user2              User      @relation("User2", fields: [user2_id], references: [id], onDelete: Cascade)
  pinned_message     Message?  @relation("PinnedInConversation", fields: [pinned_message_id], references: [id], onDelete: SetNull)
  messages           Message[] @relation("ConversationMessages")

  @@unique([user1_id, user2_id])
  @@index([user1_id])
  @@index([user2_id])
  @@index([last_message_at])
  @@index([dm_request_pending_for_user_id])
}

/// Groupe de messagerie (CDC : chat en groupe)
model ConversationGroup {
  id                 String    @id @default(uuid())
  name               String
  /// Texte d’info pour les membres (règles, lien, etc.) — éditable par les admins
  description        String?
  invite_token       String?   @unique
  avatar_url         String?
  created_by_id      String
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  last_message_at    DateTime?
  last_message_text  String?
  pinned_message_id  String?   @unique
  created_by         User      @relation("ConversationGroupCreator", fields: [created_by_id], references: [id], onDelete: Cascade)
  members            ConversationGroupMember[]
  messages           GroupMessage[]
  pinned_message     GroupMessage? @relation("GroupPinnedMessage", fields: [pinned_message_id], references: [id], onDelete: SetNull)
  group_calls        GroupCall[]

  @@index([created_by_id])
  @@index([last_message_at])
}

model ConversationGroupMember {
  id            String   @id @default(uuid())
  group_id      String
  user_id       String
  role          String   @default("member")
  joined_at     DateTime @default(now())
  /// Dernière lecture du fil groupe (non-lus = messages après cette date, hors propres envois)
  last_read_at  DateTime?
  /// Pas de notification (in-app + push) pour ce groupe pour cet utilisateur
  notifications_muted Boolean @default(false)
  /// Libellé affiché à côté du nom dans ce groupe uniquement (ex. « Parent », « Admin ») — CDC messagerie
  group_display_tag String?
  group         ConversationGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([group_id, user_id])
  @@index([group_id])
  @@index([user_id])
}

model GroupMessage {
  id                  String            @id @default(uuid())
  group_id            String
  sender_id           String
  content             String
  type                String            @default("text")
  /// sent | scheduled — livraison différée (CDC messages programmés)
  status              String            @default("sent")
  scheduled_at        DateTime?
  media_url           String?
  thumbnail_url       String?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  is_deleted          Boolean           @default(false)
  /// Message modifié par l’expéditeur (délai 15 min, texte uniquement)
  is_edited           Boolean           @default(false)
  read_by             Json?
  hidden_from_user_ids Json?
  reply_to_id         String?
  reactions           Json?
  transcription_text  String?
  /// Sondage : libellés des choix (type = poll)
  poll_options        Json?
  /// Sondage : votes { "userId": optionIndex }
  poll_votes          Json?
  /// Partage événement (type = event)
  event_id            String?
  /// Message groupe d’origine lors d’un transfert (CDC : limite une cible / traçabilité)
  forwarded_from_message_id String?
  group               ConversationGroup  @relation(fields: [group_id], references: [id], onDelete: Cascade)
  event_ref           Event?             @relation("GroupMessageSharedEvent", fields: [event_id], references: [id], onDelete: SetNull)
  sender              User               @relation(fields: [sender_id], references: [id], onDelete: Cascade)
  reply_to            GroupMessage?      @relation("GroupMessageReplyThread", fields: [reply_to_id], references: [id], onDelete: SetNull)
  replies             GroupMessage[]     @relation("GroupMessageReplyThread")
  pinned_in_group     ConversationGroup? @relation("GroupPinnedMessage")

  @@index([group_id])
  @@index([sender_id])
  @@index([created_at])
  @@index([event_id])
  @@index([status])
  @@index([scheduled_at])
  @@index([sender_id, forwarded_from_message_id])
}

model Message {
  id                   String          @id @default(uuid())
  conversation_id      String
  sender_id            String
  content              String
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt
  scheduled_at         DateTime?
  type                 String          @default("text")
  status               String          @default("sent")
  media_url            String?
  thumbnail_url        String?
  is_edited            Boolean         @default(false)
  is_deleted           Boolean         @default(false)
  deleted_for_all_at   DateTime?       // CPO 4.17 — suppression pour tous (délai limité)
  read_by              Json?
  /// Utilisateurs ayant masqué ce message « pour moi » (sync multi-appareils).
  hidden_from_user_ids Json?
  reply_to_message_id  String?
  is_important         Boolean         @default(false)
  is_pinned            Boolean         @default(false)
  reactions            Json?
  is_ephemeral         Boolean         @default(false)
  expires_at           DateTime?
  location_lat         Float?
  location_lng         Float?
  location_label       String?
  contact_user_id      String?
  contact_name         String?
  sticker_url          String?
  transcription_text  String?
  /// Sondage 1-1 : libellés des choix (type = poll)
  poll_options        Json?
  /// Sondage 1-1 : votes { "userId": optionIndex }
  poll_votes          Json?
  /// Partage événement (type = event) — titre dupliqué dans content pour aperçu / recherche
  event_id            String?
  conversation         Conversation    @relation("ConversationMessages", fields: [conversation_id], references: [id], onDelete: Cascade)
  event_ref            Event?          @relation("DmMessageSharedEvent", fields: [event_id], references: [id], onDelete: SetNull)
  pinned_in            Conversation?   @relation("PinnedInConversation")
  reply_to             Message?        @relation("Reply", fields: [reply_to_message_id], references: [id])
  replies              Message[]       @relation("Reply")
  sender               User            @relation(fields: [sender_id], references: [id], onDelete: Cascade)
  reports              MessageReport[]

  @@index([conversation_id])
  @@index([conversation_id, created_at])
  @@index([sender_id])
  @@index([created_at])
  @@index([status])
  @@index([is_pinned])
  @@index([is_important])
  @@index([expires_at])
  @@index([scheduled_at])
  @@index([sender_id], map: "idx_messages_sender")
  @@index([event_id])
}

