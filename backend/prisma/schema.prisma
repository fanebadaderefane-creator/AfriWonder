  comment      String? @db.Text
  created_at   DateTime @default(now())
  from_user    User     @relation("CompanyRatingsGiven", fields: [from_user_id], references: [id], onDelete: Cascade)
  to_user      User     @relation("CompanyRatingsReceived", fields: [to_user_id], references: [id], onDelete: Cascade)

  @@unique([from_user_id, to_user_id, job_id])
  @@index([to_user_id])
}

model CandidateRating {
  id          String   @id @default(uuid())
  from_user_id String  // employer
  to_user_id   String  // candidate
  job_id       String
  rating       Int     // 1-5
  comment      String? @db.Text
  created_at   DateTime @default(now())
  from_user    User     @relation("CandidateRatingsGiven", fields: [from_user_id], references: [id], onDelete: Cascade)
  to_user      User     @relation("CandidateRatingsReceived", fields: [to_user_id], references: [id], onDelete: Cascade)

  @@unique([from_user_id, to_user_id, job_id])
  @@index([to_user_id])
}

model SavedJob {
  id        String   @id @default(uuid())
  job_id    String
  user_id   String
  created_at DateTime @default(now())
  job       Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([job_id, user_id])
  @@index([job_id])
  @@index([user_id])
}

// ============================================
// MODULE SERVICES LOCAUX
// ============================================

model ServiceProvider {
  id                 String                  @id @default(uuid())
  user_id            String                  @unique
  status             String                  @default("pending") // pending/active/suspended/blocked
  is_verified        Boolean                 @default(false)
  verification_badge String? // verified/premium/expert
  kyc_status         String                  @default("pending") // pending/approved/rejected
  kyc_document_url   String?
  kyc_selfie_url     String?
  service_categories String[]                @default([])
  service_radius_km  Float                   @default(10) // Rayon de couverture en km
  location_type      String                  @default("both") // on_site/home/both
  average_rating     Float                   @default(0)
  total_bookings     Int                     @default(0)
  total_earnings     Float                   @default(0)
  payout_method      String? // orange_money/mtn_money/wave/bank_transfer
  payout_account     String? // Numéro de compte pour payout
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  user               User                    @relation("ServiceProvider", fields: [user_id], references: [id], onDelete: Cascade)
  services           Service[]
  bookings           ServiceBooking[]        @relation("Provider")
  availabilities     ServiceAvailability[]
  unavailabilities   ServiceUnavailability[]
  reviews            ServiceReview[]
  payouts            ServicePayout[]
  disputes           ServiceDispute[]

  @@index([user_id])
  @@index([status])
  @@index([is_verified])
  @@index([kyc_status])
  @@index([service_categories])
}

model ServiceCategory {
  id          String            @id @default(uuid())
  name        String            @unique
  slug        String            @unique
  description String?
  icon_url    String?
  parent_id   String?
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  parent      ServiceCategory?  @relation("CategoryParent", fields: [parent_id], references: [id], onDelete: SetNull)
  children    ServiceCategory[] @relation("CategoryParent")
  services    Service[]

  @@index([slug])
  @@index([parent_id])
  @@index([is_active])
}

model Service {
  id             String           @id @default(uuid())
  provider_id    String
  title          String
  description    String
  price          Float
  currency       String           @default("XOF")
  duration       Int? // Durée estimée en minutes
  category       String?
  category_id    String?
  location       String?
  location_type  String           @default("both") // on_site/home/both
  travel_fee     Float            @default(0) // Frais de déplacement
  is_available   Boolean          @default(true)
  rating         Float            @default(0)
  total_bookings Int              @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  provider       ServiceProvider  @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  category_ref   ServiceCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  bookings       ServiceBooking[]
  reviews        ServiceReview[]

  @@index([provider_id])
  @@index([category])
  @@index([category_id])
  @@index([is_available])
  @@index([location_type])
}

model ServiceBooking {
  id                     String          @id @default(uuid())
  service_id             String
  customer_id            String
  provider_id            String
  status                 String          @default("pending") // pending/confirmed/in_progress/completed/cancelled/no_show
  booking_date           DateTime
  booking_time           String // Format HH:mm
  duration               Int // Durée en minutes
  location_type          String // customer_address/provider_location
  customer_address_id    String?
  provider_address_id    String?
  customer_address       Address?        @relation("BookingCustomerAddress", fields: [customer_address_id], references: [id], onDelete: SetNull)
  provider_address       Address?        @relation("BookingProviderAddress", fields: [provider_address_id], references: [id], onDelete: SetNull)
  total_price            Float
  platform_fee           Float
  provider_earnings      Float
  payment_status         String          @default("pending") // pending/partial/paid/refunded
  payment_method         String? // orange_money/mtn_money/wave/card/wallet
  payment_transaction_id String?
  deposit_amount         Float           @default(0)
  deposit_paid           Boolean         @default(false)
  notes                  String?
  cancellation_reason    String?
  cancelled_by           String? // customer/provider/admin
  confirmed_at           DateTime?
  started_at             DateTime?
  completed_at           DateTime?
  cancelled_at           DateTime?
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  service                Service         @relation(fields: [service_id], references: [id], onDelete: Cascade)
  customer               User            @relation("BookingCustomer", fields: [customer_id], references: [id], onDelete: Cascade)
  provider               ServiceProvider @relation("Provider", fields: [provider_id], references: [id], onDelete: Cascade)
  review                 ServiceReview?
  dispute                ServiceDispute?

  @@index([service_id])
  @@index([customer_id])
  @@index([provider_id])
  @@index([status])
  @@index([booking_date])
  @@index([payment_status])
  @@index([customer_id, status])
  @@index([provider_id, status])
}

model ServiceAvailability {
  id            String          @id @default(uuid())
  provider_id   String
  day_of_week   Int // 0 (Dimanche) à 6 (Samedi)
  start_time    String // Format HH:mm
  end_time      String // Format HH:mm
  is_available  Boolean         @default(true)
  is_recurring  Boolean         @default(true) // Récurrent ou exception
  specific_date DateTime? // Pour exceptions (si is_recurring = false)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  provider      ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([provider_id])
  @@index([day_of_week])
  @@index([specific_date])
  @@index([provider_id, day_of_week])
}

model ServiceUnavailability {
  id          String          @id @default(uuid())
  provider_id String
  start_date  DateTime
  end_date    DateTime
  reason      String // holiday/vacation/other
  notes       String?
  created_at  DateTime        @default(now())
  provider    ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([provider_id])
  @@index([start_date])
  @@index([end_date])
  @@index([provider_id, start_date, end_date])
}

model ServiceReview {
  id            String          @id @default(uuid())
  booking_id    String          @unique
  service_id    String
  provider_id   String
  customer_id   String
  rating        Int // 1-5
  title         String?
  content       String
  photos        String[]        @default([])
  is_verified   Boolean         @default(false) // Client a utilisé le service
  helpful_count Int             @default(0)
  status        String          @default("approved") // pending/approved/rejected
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  booking       ServiceBooking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  service       Service         @relation(fields: [service_id], references: [id], onDelete: Cascade)
  provider      ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  customer      User            @relation("ServiceReviewCustomer", fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([service_id])
  @@index([provider_id])
  @@index([customer_id])
  @@index([rating])
  @@index([status])
  @@index([service_id, status])
  @@index([provider_id, rating])
}

model ServiceDispute {
  id            String          @id @default(uuid())
  booking_id    String          @unique
  reporter_id   String // customer_id ou provider_id
  reporter_type String // customer/provider
  reason        String
  description   String?
  evidence      String[]        @default([])
  status        String          @default("pending") // pending/investigating/resolved/rejected
  resolution    String?
  resolved_by   String?
  resolved_at   DateTime?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  booking       ServiceBooking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  provider      ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  provider_id   String

  @@index([booking_id])
  @@index([reporter_id])
  @@index([provider_id])
  @@index([status])
  @@index([reporter_id, status])
}

model ServicePayout {
  id                String          @id @default(uuid())
  provider_id       String
  amount            Float
  currency          String          @default("XOF")
  commission_rate   Float // Taux commission plateforme (ex: 0.1 pour 10%)
  commission_amount Float
  net_amount        Float
  status            String          @default("pending") // pending/processing/completed/failed
  payout_method     String
  payout_account    String
  booking_ids       String[]        @default([]) // IDs des réservations incluses
  processed_at      DateTime?
  completed_at      DateTime?
  failure_reason    String?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  provider          ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([provider_id])
  @@index([status])
  @@index([created_at])
  @@index([provider_id, status])
}

model Event {
  id               String    @id @default(uuid())
  title            String
  description      String?
  category         String?
  image            String?
  organizer_id     String
  organizer_name   String?
  start_date       DateTime
  end_date         DateTime
  location         String?
  latitude         Float?
  longitude        Float?
  event_type       String    @default("physical") // physical | virtual | hybrid
  capacity         Int?      // null = illimité
  price            Float?    @default(0)
  currency         String    @default("XOF")
  is_free          Boolean   @default(true)
  is_featured      Boolean   @default(false)
  featured_until   DateTime?
  status           String    @default("draft") // draft | published | cancelled | completed
  virtual_url      String?   // Zoom, Google Meet, stream URL
  replay_url       String?
  refund_policy    String?   // texte politique remboursement
  faq              Json?     // [{ question, answer }]
  speakers         Json?     // [{ name, role, photo? }] section intervenants
  sponsors         Json?     // [{ name, logo_url?, link? }] partenaires
  platform_fee_pct Float?    @default(10) // commission 5-15%
  attendees_count  Int       @default(0) // dénombré à partir des billets payés/check-in
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  organizer        User      @relation(fields: [organizer_id], references: [id], onDelete: Cascade)
  ticket_types     EventTicketType[]
  tickets          EventTicket[]
  attendances      EventAttendance[]
  payments         EventPayment[]
  likes            EventLike[]
  comments         EventComment[]
  featured_payments EventFeaturedPayment[]
  chat_messages   EventChatMessage[]
  ticket_locks     TicketLock[]

  @@index([organizer_id])
  @@index([start_date])
  @@index([category])
  @@index([status])
  @@index([event_type])
  @@index([location])
}

// Stock par type de billet (scalable, temps réel)
model EventTicketType {
  id                  String    @id @default(uuid())
  event_id            String
  name                String    // standard | vip | early_bird
  description         String?
  price               Float     @default(0)
  currency            String    @default("XOF")
  quantity_available  Int       @default(0)  // stock total
  quantity_sold       Int       @default(0)  // vendus
  max_per_user        Int?      // null = illimité
  sale_start          DateTime?
  sale_end            DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  event               Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  tickets             EventTicket[]

  @@unique([event_id, name])
  @@index([event_id])
  @@map("event_ticket_types")
}

// Lock temporaire (2 min) pour éviter survente pendant checkout
model TicketLock {
  id             String   @id @default(uuid())
  event_id       String
  ticket_type    String   // nom du type (standard, vip, etc.)
  user_id        String
  quantity       Int      @default(1)
  expires_at     DateTime
  created_at     DateTime @default(now())
  event          Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([event_id])
  @@index([user_id])
  @@index([expires_at])
  @@map("ticket_locks")
}

model EventTicket {
  id               String    @id @default(uuid())
  event_id         String
  event_ticket_type_id String?
  user_id          String
  ticket_type      String    @default("standard") // standard | vip | early_bird
  price            Float     @default(0)
  currency         String    @default("XOF")
  payment_status   String    @default("pending") // pending | paid | refunded
  payment_method   String?
  transaction_id   String?
  qr_code          String?   @unique // token unique pour check-in (affiché)
  qr_signature     String?   // HMAC pour anti-fraude scan
  checked_in       Boolean   @default(false)
  checked_in_at    DateTime?
  scan_count      Int       @default(0) // anti-double: incremented at each scan attempt
  city             String?   // ville du participant (analytics)
  source           String?   // source inscription: mobile_web, desktop, app, etc.
  created_at       DateTime  @default(now())
  event            Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  event_ticket_type EventTicketType? @relation(fields: [event_ticket_type_id], references: [id], onDelete: SetNull)
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id])
  @@index([user_id])
  @@index([qr_code])
  @@index([payment_status])
}

model EventAttendance {
  id         String   @id @default(uuid())
  event_id   String
  user_id    String
  role       String   @default("participant") // participant | speaker | staff
  status     String   @default("registered") // registered | cancelled | attended
  created_at DateTime @default(now())
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@index([event_id])
  @@index([user_id])
  @@index([status])
}

model EventPayment {
  id               String    @id @default(uuid())
  event_id         String
  user_id          String
  amount           Float
  currency         String    @default("XOF")
  provider         String    // orange_money, mtn_money, wave, flutterwave, paystack, card, cod
  transaction_id   String?
  status           String    @default("pending") // pending | completed | failed | refunded
  paid_at          DateTime?
  refunded_at      DateTime?
  city             String?   // ville participant (analytics)
  source           String?   // source inscription
  created_at       DateTime  @default(now())
  event            Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id])
  @@index([user_id])
  @@index([transaction_id])
  @@index([status])
}

model EventLike {
  id         String   @id @default(uuid())
  event_id   String
  user_id    String
  created_at DateTime @default(now())
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@index([event_id])
  @@index([user_id])
}

model EventComment {
  id         String   @id @default(uuid())
  event_id   String
  user_id    String
  content    String
  created_at DateTime @default(now())
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id])
  @@index([user_id])
}

model EventFeaturedPayment {
  id             String    @id @default(uuid())
  event_id       String
  user_id        String
  amount         Float
  currency       String    @default("XOF")
  provider       String
  status         String    @default("pending") // pending | completed | failed
  paid_at        DateTime?
  featured_until DateTime?
  created_at     DateTime  @default(now())
  event          Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id])
  @@index([user_id])
  @@index([status])
}

model EventChatMessage {
  id         String   @id @default(uuid())
  event_id   String
  user_id    String
  content    String
  created_at DateTime @default(now())
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id])
  @@index([user_id])
  @@index([created_at])
}

model CivicPetition {
  id                     String              @id @default(uuid())
  creator_id             String
  title                  String
  description            String
  goal_signatures        Int
  current_signatures     Int                 @default(0)
  status                 String              @default("active")
  end_date               DateTime?
  category               String?
  country                String?
  region                 String?
  city                   String?
  is_national            Boolean             @default(true)
  shares_count           Int                 @default(0)
  target_authority_email String?
  is_boosted             Boolean             @default(false)
  is_featured            Boolean             @default(false)
  featured_until          DateTime?
  created_at             DateTime            @default(now())
  updated_at             DateTime            @updatedAt
  creator                User                @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  signatures             PetitionSignature[]
  comments               PetitionComment[]
  saved_by               SavedPetition[]

  @@index([creator_id])
  @@index([status])
  @@index([country])
  @@index([category])
  @@index([is_featured])
}

model PetitionSignature {
  id            String        @id @default(uuid())
  petition_id   String
  signer_id     String
  comment       String?
  is_verified   Boolean       @default(false)
  ip_address    String?
  signer_city   String?
  signer_country String?
  created_at    DateTime      @default(now())
  petition      CivicPetition @relation(fields: [petition_id], references: [id], onDelete: Cascade)
  signer        User          @relation("PetitionSigner", fields: [signer_id], references: [id], onDelete: Cascade)

  @@unique([petition_id, signer_id])
  @@index([petition_id])
  @@index([signer_id])
}

model PetitionComment {
  id          String             @id @default(uuid())
  petition_id String
  user_id     String
  parent_id   String?
  content     String             @db.Text
  created_at  DateTime           @default(now())
  petition    CivicPetition      @relation(fields: [petition_id], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent      PetitionComment?   @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies     PetitionComment[]  @relation("CommentReplies")
  likes       PetitionCommentLike[]

  @@index([petition_id])
  @@index([user_id])
  @@index([parent_id])
}

model PetitionCommentLike {
  id         String          @id @default(uuid())
  comment_id String
  user_id    String
  created_at DateTime        @default(now())
  comment    PetitionComment @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, user_id])
  @@index([comment_id])
  @@index([user_id])
}

model SavedPetition {
  id          String        @id @default(uuid())
  petition_id String
  user_id     String
  created_at  DateTime      @default(now())
  petition    CivicPetition  @relation(fields: [petition_id], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([petition_id, user_id])
  @@index([petition_id])
  @@index([user_id])
}

model NewsArticle {
  id                String    @id @default(uuid())
  title             String
  slug              String    @unique
  subtitle          String?
  content           String    // rich text
  excerpt           String?
  featured_image    String?
  category          String?
  tags              Json?     // string[]
  country           String?
  language          String    @default("FR")
  author_id         String
  author_name       String?
  author_avatar     String?
  is_breaking       Boolean   @default(false)
  breaking_priority Int?      // 1-5
  breaking_expiry_at DateTime?
  is_verified       Boolean   @default(false)
  is_published      Boolean   @default(false)
  is_sponsored      Boolean   @default(false)
  is_featured       Boolean   @default(false)
  is_premium        Boolean   @default(false)
  status            String    @default("draft") // draft | review | published | archived
  views             Int       @default(0)
  likes_count       Int       @default(0)
  comments_count    Int       @default(0)
  shares_count      Int       @default(0)
  reading_time      Int?      // minutes
  seo_title         String?
  seo_description   String?
  published_at      DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  verified_source_id String?
  author            User      @relation(fields: [author_id], references: [id], onDelete: Cascade)
  verified_source   VerifiedSource? @relation(fields: [verified_source_id], references: [id])
  article_views     ArticleView[]
  article_likes     ArticleLike[]
  article_comments  ArticleComment[]
  trending          TrendingArticle[]

  @@index([author_id])
  @@index([category])
  @@index([country])
  @@index([language])
  @@index([status])
  @@index([is_published])
  @@index([is_breaking])
  @@index([published_at])
  @@index([verified_source_id])
}

model ArticleView {
  id         String      @id @default(uuid())
  article_id String
  user_id    String?
  ip_hash    String      // hash for anonymous; 1 view per (user_id or ip_hash) per 24h enforced in service
  viewed_at  DateTime    @default(now())
  article    NewsArticle @relation(fields: [article_id], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([article_id])
  @@index([user_id])
  @@index([viewed_at])
  @@index([article_id, ip_hash])
}

model ArticleLike {
  id         String      @id @default(uuid())
  article_id String
  user_id    String
  created_at DateTime    @default(now())
  article    NewsArticle @relation(fields: [article_id], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([article_id, user_id])
  @@index([article_id])
  @@index([user_id])
}

model ArticleComment {
  id         String           @id @default(uuid())
  article_id String
  user_id    String
  parent_id  String?
  content    String
  is_deleted Boolean          @default(false)
  is_reported Boolean         @default(false)
  created_at DateTime         @default(now())
  article    NewsArticle      @relation(fields: [article_id], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent     ArticleComment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: SetNull)
  replies    ArticleComment[] @relation("CommentReplies")

  @@index([article_id])
  @@index([user_id])
  @@index([parent_id])
}

model UserNewsPreference {
  id                   String   @id @default(uuid())
  user_id              String   @unique
  preferred_categories  Json?    // string[]
  preferred_country    String?
  preferred_language   String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model TrendingArticle {
  id          String      @id @default(uuid())
  article_id  String      @unique
  score       Float
  calculated_at DateTime  @default(now())
  article     NewsArticle @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@index([score])
}

model VerifiedSource {
  id          String        @id @default(uuid())
  name        String
  logo        String?
  website     String?
  trust_score Int?          // 0-100
  created_at  DateTime      @default(now())
  articles    NewsArticle[]

  @@index([name])
}

model NewsPremiumSubscription {
  id         String   @id @default(uuid())
  user_id   String
  plan      String   // monthly | yearly
  expires_at DateTime
  created_at DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model Challenge {
  id                 String   @id @default(uuid())
  creator_id         String
  title              String
  description        String
  start_date         DateTime
  end_date           DateTime
  prize              String?
  participants_count Int      @default(0)
  status             String   @default("active")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@index([creator_id])
  @@index([status])
  @@index([end_date])
}

model Referral {
  id            String    @id @default(uuid())
  referrer_id   String
  referred_id   String
  reward_amount Float     @default(0)
  status        String    @default("pending")
  completed_at  DateTime?
  created_at    DateTime  @default(now())
  referrer      User      @relation("Referrer", fields: [referrer_id], references: [id], onDelete: Cascade)
  referred      User      @relation("Referred", fields: [referred_id], references: [id], onDelete: Cascade)

  @@unique([referrer_id, referred_id])
  @@index([referrer_id])
  @@index([referred_id])
}

// =====================================================
// RIDE / TRANSPORT
// =====================================================

model Ride {
  id                    String    @id @default(uuid())
  passenger_id          String
  passenger_name        String?
  passenger_phone      String?
  driver_id             String?
  driver_name           String?
  driver_phone          String?
  driver_avatar         String?
  vehicle_type          String    @default("moto") // moto | car | tricycle | van
  pickup_location       String
  pickup_lat            Float?
  pickup_lng            Float?
  dropoff_location     String
  dropoff_lat           Float?
  dropoff_lng           Float?
  distance_km           Float?
  estimated_duration_min Int?
  price                 Float?
  currency              String    @default("XOF")
  status                String    @default("requested") // requested | accepted | driver_arriving | in_progress | completed | cancelled
  payment_method        String    @default("cash") // cash | wallet | mobile_money | card
  rating                Float?
  driver_rating         Float?
  tip_amount           Float     @default(0)
  cancellation_fee     Float     @default(0)
  cancellation_reason  String?
  notes                 String?
  completed_at         DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  passenger             User      @relation("RidePassenger", fields: [passenger_id], references: [id], onDelete: Cascade)
  driver                User?     @relation("RideDriver", fields: [driver_id], references: [id], onDelete: SetNull)

  @@index([passenger_id])
  @@index([driver_id])
  @@index([status])
  @@index([created_at])
}

model Driver {
  id                     String   @id @default(uuid())
  user_id                String   @unique
  full_name              String
  phone                  String
  email                  String?
  avatar                 String?
  vehicle_type           String   // moto | car | tricycle | van
  vehicle_brand          String?
  vehicle_model          String?
  vehicle_color          String?
  license_plate          String
  license_number         String?
  license_expiry         DateTime? @db.Date
  rating                 Float    @default(5.0)
  total_rides            Int      @default(0)
  total_earnings         Float    @default(0)
  status                 String   @default("offline") // offline | available | busy
  current_location       String?
  current_lat            Float?
  current_lng            Float?
  is_verified            Boolean  @default(false)
  verification_documents Json?    @default("[]") // string[]
  bank_account           String?
  available_seats        Int      @default(1)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
  user                   User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([vehicle_type])
}

// =====================================================
// RESTAURANT & FOOD DELIVERY
// =====================================================

model Restaurant {
  id                 String    @id @default(uuid())
  owner_id           String
  name               String
  description        String?
  logo_url           String?
  banner_url         String?
  cuisine_type       Json?     @default("[]") // string[] enum: africain, senegalais, ...
  address            String
  city               String?
  latitude           Float?
  longitude          Float?
  phone              String
  opening_hours      String?
  delivery_time_min  Int       @default(30)
  minimum_order      Float     @default(0)
  delivery_fee       Float     @default(0)
  rating             Float     @default(5.0)
  total_reviews      Int       @default(0)
  total_orders       Int       @default(0)
  is_open            Boolean   @default(true)
  is_verified        Boolean   @default(false)
  accepts_orders     Boolean   @default(true)
  tags               Json?     @default("[]") // string[]
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  owner              User      @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  menu_items         MenuItem[]
  food_orders        FoodOrder[]

  @@index([owner_id])
  @@index([city])
  @@index([is_open])
}

model MenuItem {
  id                  String   @id @default(uuid())
  restaurant_id       String
  restaurant_name     String?
  name                String
  description         String?
  category            String   @default("plats") // entrees | plats | desserts | boissons | accompagnements | menu_complet
  price               Float
  currency            String   @default("XOF")
  image_url           String?
  images              Json?    @default("[]") // string[]
  preparation_time_min Int     @default(20)
  calories            Int?
  is_available        Boolean  @default(true)
  is_popular          Boolean  @default(false)
  is_spicy            Boolean  @default(false)
  is_vegetarian       Boolean  @default(false)
  allergens           Json?    @default("[]") // string[]
  options             Json?    @default("[]") // object[]
  discount_percent    Float    @default(0)
  orders_count       Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  restaurant          Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@index([restaurant_id])
  @@index([category])
}

model FoodOrder {
  id                    String    @id @default(uuid())
  customer_id           String
  customer_name         String?
  customer_phone        String?
  restaurant_id         String
  restaurant_name       String?
  items                 Json      // array of order items
  subtotal              Float?
  delivery_fee           Float     @default(0)
  service_fee           Float     @default(0)
  total_amount          Float
  currency              String    @default("XOF")
  delivery_address      String
  delivery_lat          Float?
  delivery_lng          Float?
  delivery_instructions String?
  payment_method        String    @default("cash") // cash | wallet | mobile_money | card
  status                String    @default("pending") // pending | confirmed | preparing | ready | picked_up | on_the_way | delivered | cancelled
  delivery_person_id    String?
  delivery_person_name  String?
  delivery_person_phone String?
  estimated_delivery_time DateTime?
  delivered_at          DateTime?
  rating                Float?
  review                String?
  special_requests      String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  customer              User      @relation("FoodOrderCustomer", fields: [customer_id], references: [id], onDelete: Cascade)
  delivery_person       User?     @relation("FoodOrderDelivery", fields: [delivery_person_id], references: [id], onDelete: SetNull)
  restaurant            Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@index([restaurant_id])
  @@index([delivery_person_id])
  @@index([status])
}

// =====================================================
// AIRTIME & BILL PAYMENTS
// =====================================================

model AirtimeRecharge {
  id               String    @id @default(uuid())
  user_id          String
  phone_number     String
  operator         String    // Orange | MTN | Moov | Airtel | Togocel | Vodacom | Safaricom
  amount           Float
  currency         String    @default("XOF")
  payment_method   String    @default("wallet") // wallet | mobile_money | card
  status           String    @default("pending") // pending | processing | completed | failed | refunded
  transaction_id   String?
  reference        String?
  bonus_amount     Float     @default(0)
  is_self_recharge Boolean   @default(true)
  recipient_name   String?
  completed_at     DateTime?
  created_at       DateTime  @default(now())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([created_at])
}

model BillPayment {
  id             String    @id @default(uuid())
  user_id        String
  bill_type      String    // electricity | water | internet | tv | insurance | school_fees | government_tax
  provider       String
  account_number String
  customer_name  String?
  amount         Float
  currency       String    @default("XOF")
  payment_method String    @default("wallet") // wallet | mobile_money | card
  status         String    @default("pending") // pending | processing | completed | failed | refunded
  reference      String?
  transaction_id String?
  due_date       DateTime? @db.Date
  bill_period    String?
  fees           Float     @default(0)
  is_recurring   Boolean   @default(false)
  completed_at   DateTime?
  created_at     DateTime  @default(now())
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([bill_type])
  @@index([status])
}

// =====================================================
// TICKETS (EVENTS, CINEMA, ETC.)
// =====================================================

model Ticket {
  id                String    @id @default(uuid())
  user_id           String
  ticket_type       String    // event | concert | cinema | transport | sports | theater
  event_id          String?
  event_name        String?
  event_date        DateTime?
  venue             String?
  seat_number       String?
  section           String?
  price             Float
  currency          String    @default("XOF")
  quantity          Int       @default(1)
  total_amount      Float?
  payment_method    String    @default("wallet") // wallet | mobile_money | card
  status            String    @default("pending") // pending | confirmed | used | cancelled | refunded
  qr_code           String?
  ticket_number     String?
  organizer_name    String?
  organizer_contact String?
  terms_conditions  String?
  is_transferable   Boolean   @default(false)
  used_at           DateTime?
  created_at        DateTime  @default(now())
  user              User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([ticket_type])
  @@index([status])
}

// =====================================================
// HEALTH (DOCTOR & APPOINTMENTS)
// =====================================================

model Doctor {
  id                   String    @id @default(uuid())
  user_id              String    @unique
  full_name            String
  specialty            String   // general | pediatrie | gynecologie | dentiste | ophtalmologie | dermatologie | cardiologie | psychiatrie | autre
  qualifications       Json?     @default("[]") // string[]
  license_number       String?
  years_experience     Int?
  profile_photo        String?
  bio                  String?
  languages            Json?     // string[] e.g. ["francais"]
  clinic_name         String?
  clinic_address      String?
  city                 String?
  phone                String
  email                String?
  consultation_fee     Float?
  currency             String    @default("XOF")
  accepts_telemedicine Boolean   @default(true)
  accepts_insurance    Boolean   @default(false)
  rating               Float     @default(5.0)
  total_consultations  Int       @default(0)
  is_verified          Boolean   @default(false)
  is_available        Boolean   @default(true)
  available_hours     String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  appointments        Appointment[]

  @@index([user_id])
  @@index([specialty])
  @@index([city])
}

model Appointment {
  id                   String    @id @default(uuid())
  patient_id           String
  patient_name         String?
  patient_phone        String?
  patient_age          Int?
  doctor_id            String
  doctor_name          String?
  doctor_specialty     String?
  appointment_type     String    @default("telemedicine") // telemedicine | in_person | follow_up
  appointment_date     DateTime
  duration_minutes     Int       @default(30)
  reason               String
  symptoms             String?
  status               String    @default("scheduled") // scheduled | confirmed | in_progress | completed | cancelled | no_show
  consultation_fee     Float?
  currency             String    @default("XOF")
  payment_status       String    @default("pending") // pending | paid | refunded
  payment_method       String?   // wallet | mobile_money | cash | insurance
  video_call_link      String?
  prescription         String?
  prescription_file_url String?
  medical_notes        String?
  follow_up_required   Boolean   @default(false)
  rating               Float?
  completed_at         DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  patient              User      @relation("AppointmentPatient", fields: [patient_id], references: [id], onDelete: Cascade)
  doctor               Doctor    @relation(fields: [doctor_id], references: [id], onDelete: Cascade)

  @@index([patient_id])
  @@index([doctor_id])
  @@index([appointment_date])
  @@index([status])
}

// =====================================================
// PHARMACY
// =====================================================

model Pharmacy {
  id                    String   @id @default(uuid())
  name                  String
  owner_id              String?
  license_number        String?
  address               String
  city                  String?
  latitude              Float?
  longitude             Float?
  phone                 String
  opening_hours         String?
  is_24h                Boolean  @default(false)
  offers_delivery       Boolean  @default(true)
  delivery_fee          Float    @default(0)
  minimum_order         Float    @default(0)
  rating                Float    @default(5.0)
  total_orders          Int      @default(0)
  is_verified           Boolean  @default(false)
  accepts_prescriptions Boolean  @default(true)
  pharmacist_name       String?
  logo_url              String?
  services              Json?    @default("[]") // string[]
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  owner                 User?    @relation(fields: [owner_id], references: [id], onDelete: SetNull)

  @@index([owner_id])
  @@index([city])
}

// =====================================================
// PROPERTY (REAL ESTATE)
// =====================================================

model Property {
  id                String   @id @default(uuid())
  owner_id          String
  owner_name        String?
  owner_phone       String?
  listing_type      String   // rent | sale
  property_type     String   // apartment | house | studio | villa | land | office | shop | warehouse
  title             String
  description       String?
  address           String
  city              String?
  neighborhood      String?
  latitude          Float?
  longitude         Float?
  price             Float
  currency          String   @default("XOF")
  bedrooms          Int?
  bathrooms         Int?
  surface_area      Float?
  floor             Int?
  total_floors      Int?
  is_furnished      Boolean  @default(false)
  amenities         Json?    @default("[]") // string[]
  images            Json?     @default("[]") // string[]
  video_url         String?
  year_built        Int?
  available_from    DateTime? @db.Date
  status            String   @default("available") // available | rented | sold | reserved
  views             Int      @default(0)
  saved_count       Int      @default(0)
  is_verified       Boolean  @default(false)
  deposit_required  Float?
  utilities_included Boolean @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  owner             User     @relation(fields: [owner_id], references: [id], onDelete: Cascade)

  visit_requests       PropertyVisitRequest[]
  @@index([owner_id])
  @@index([listing_type])
  @@index([property_type])
  @@index([city])
  @@index([status])
}

model PropertyVisitRequest {
  id             String   @id @default(uuid())
  property_id    String
  user_id        String
  requested_date DateTime? @db.Date
  message        String?
  status         String   @default("pending") // pending | accepted | rejected | completed
  owner_notes    String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  property       Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([property_id])
  @@index([user_id])
  @@index([status])
}

// =====================================================
// INSURANCE
// =====================================================

model InsurancePolicy {
  id                 String    @id @default(uuid())
  user_id            String
  policy_type        String    // health | vehicle | property | life | travel | micro_insurance
  policy_number      String?
  provider           String
  plan_name          String?
  coverage_amount    Float?
  premium_amount     Float
  payment_frequency  String    @default("monthly") // monthly | quarterly | yearly
  currency           String    @default("XOF")
  start_date         DateTime? @db.Date
  end_date           DateTime? @db.Date
  status             String    @default("pending") // active | expired | cancelled | pending
  beneficiaries      Json?     @default("[]") // object[]
  covered_items      Json?     @default("[]") // string[]
  exclusions         Json?     @default("[]") // string[]
  deductible         Float     @default(0)
  documents          Json?     @default("[]") // string[] URLs
  auto_renew         Boolean   @default(true)
  claims_count       Int       @default(0)
  last_payment_date  DateTime? @db.Date
  next_payment_date  DateTime? @db.Date
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  user               User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  claims             InsuranceClaim[]

  @@index([user_id])
  @@index([status])
}

model InsuranceClaim {
  id                   String   @id @default(uuid())
  user_id              String
  policy_id            String
  policy_number        String?
  claim_number         String?
  incident_date        DateTime @db.Date
  description          String
  claim_amount         Float
  approved_amount      Float    @default(0)
  currency             String   @default("XOF")
  status               String   @default("submitted") // submitted | under_review | approved | rejected | paid
  validation_level     Int      @default(0) // 0-4 workflow
  risk_score           Float?   // 0-100 fraud/risk
  supporting_documents Json?    @default("[]") // string[] URLs
  photos               Json?     @default("[]") // string[] URLs
  adjuster_name        String?
  adjuster_notes       String?
  rejection_reason     String?
  paid_date            DateTime? @db.Date
  payment_method       String?   // bank_transfer | mobile_money | check
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  policy               InsurancePolicy @relation(fields: [policy_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([policy_id])
  @@index([status])
}

// Idempotency — anti double paiement / double achat
model IdempotencyKey {
  id             String    @id @default(uuid())
  key            String    @unique
  response_status Int?
  response_body   String?   @db.Text
  created_at     DateTime  @default(now())
  expires_at     DateTime

  @@index([key])
  @@index([expires_at])
  @@map("idempotency_keys")
}

// Blacklist — user, device, IP (anti-fraude)
model BlacklistEntry {
  id         String    @id @default(uuid())
  type       String    // user | device | ip
  value      String    // user_id, device_id, or IP/range
  reason     String?
  created_by String?
  expires_at DateTime?
  created_at DateTime  @default(now())

  @@index([type, value])
  @@index([expires_at])
  @@map("blacklist_entries")
}

// Audit trail — tous mouvements financiers et actions critiques
model AuditEvent {
  id          String   @id @default(uuid())
  event_type  String   // payment_init, payment_confirm, ticket_book, ride_create, claim_submit, kyc_submit, etc.
  actor_id    String?
  target_type String?
  target_id   String?
  payload     Json?    // snapshot pertinent
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  @@index([event_type])
  @@index([actor_id])
  @@index([target_type, target_id])
  @@index([created_at])
  @@map("audit_events")
}

// Feature flags — rollout sans déploiement
model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("feature_flags")
}

// AML — transactions flaggées (seuils, reporting)
model TransactionFlag {
  id             String   @id @default(uuid())
  reference_type String   // order, event_payment, withdrawal, etc.
  reference_id   String?
  user_id        String
  amount         Float
  currency       String   @default("XOF")
  reason         String   // amount_threshold, velocity, manual
  status         String   @default("pending") // pending | reported | cleared
  created_at     DateTime @default(now())
  reviewed_at    DateTime?
  reviewed_by    String?

  @@index([user_id])
  @@index([status])
  @@index([created_at])
  @@map("transaction_flags")
}

model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String
  description String?
  category    String?
  requirement String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([category])
  @@index([is_active])
}

model UserVerification {
  id            String    @id @default(uuid())
  user_id       String    @unique
  document_type String
  document_url  String
  status        String    @default("pending")
  verified_at   DateTime?
  verified_by   String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
}

// =====================================================
// LEGAL & SECURITY MODELS (GDPR/CCPA Compliant)
// =====================================================

model LegalDocument {
  id               String                  @id @default(uuid())
  type             String                  // 'privacy_policy', 'terms_of_service', 'cookies_policy', 'data_protection'
  version          String
  language         String                  @default("fr")
  title            String
  content          String                  // Full HTML/Markdown content
  effective_date   DateTime
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt
  is_active        Boolean                 @default(false)
  created_by       String?
  acceptances      UserLegalAcceptance[]

  @@unique([type, version, language])
  @@index([type, is_active])
  @@index([effective_date])
  @@map("legal_documents")
}

model UserLegalAcceptance {
  id           String         @id @default(uuid())
  user_id      String
  document_id  String
  version      String
  accepted_at  DateTime       @default(now())
  ip_address   String?
  user_agent   String?
  device_info  Json?
  user         User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  document     LegalDocument  @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([document_id])
  @@index([accepted_at])
  @@map("user_legal_acceptances")
}

model UserCookiePreference {
  id           String   @id @default(uuid())
  user_id      String   @unique
  essential    Boolean  @default(true)
  analytics    Boolean  @default(false)
  marketing    Boolean  @default(false)
  functional   Boolean  @default(false)
  social_media Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  ip_address   String?
  user_agent   String?
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_cookie_preferences")
}

model GuestCookieConsent {
  id           String   @id @default(uuid())
  session_id   String
  essential    Boolean  @default(true)
  analytics    Boolean  @default(false)
  marketing    Boolean  @default(false)
  functional   Boolean  @default(false)
  social_media Boolean  @default(false)
  created_at   DateTime @default(now())
  ip_address   String?
  expires_at   DateTime

  @@index([session_id])
  @@map("guest_cookie_consents")
}

model DataExportRequest {
  id            String    @id @default(uuid())
  user_id       String
  status        String    @default("pending") // 'pending', 'processing', 'completed', 'failed'
  format        String    @default("json") // 'json', 'csv', 'pdf'
  requested_at  DateTime  @default(now())
  completed_at  DateTime?
  expires_at    DateTime?
  download_url  String?
  file_size     BigInt?
  error_message String?
  ip_address    String?
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([requested_at])
  @@map("data_export_requests")
}

model AccountDeletionRequest {
  id                    String    @id @default(uuid())
  user_id               String
  reason                String?
  requested_at          DateTime  @default(now())
  scheduled_deletion_at DateTime
  deleted_at            DateTime?
  status                String    @default("pending") // 'pending', 'cancelled', 'completed'
  cancellation_token    String?   @unique
  ip_address            String?
  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([scheduled_deletion_at])
  @@map("account_deletion_requests")
}

model SecurityLog {
  id          String   @id @default(uuid())
  user_id     String
  action      String // 'login', 'logout', 'password_change', 'email_change', 'withdrawal', 'account_deletion', 'login_failed', '2fa_enabled', '2fa_disabled'
  status      String   @default("success") // 'success', 'failed', 'suspicious'
  ip_address  String
  user_agent  String?
  device_info Json?
  metadata    Json?
  risk_score  Int?     @default(0)
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([action])
  @@index([created_at])
  @@index([risk_score])
  @@map("security_logs")
}

model User2FA {
  id            String    @id @default(uuid())
  user_id       String    @unique
  method        String // 'sms', 'authenticator', 'email'
  is_enabled    Boolean   @default(false)
  secret        String?
  backup_codes  String[]
  phone_number  String?
  last_used_at  DateTime?
  enabled_at    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_enabled])
  @@map("user_2fa")
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  admin_id    String
  action      String
  entity_type String?
  entity_id   String?
  changes     Json?
  ip_address  String?
  user_agent  String?
  timestamp   DateTime @default(now())
  admin       User     @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@index([entity_type, entity_id])
  @@index([timestamp])
  @@map("admin_audit_logs")
}

model SuspiciousActivityAlert {
  id          String    @id @default(uuid())
  user_id     String
  alert_type  String // 'new_country', 'multiple_failed_logins', 'unusual_withdrawal', 'rapid_transactions'
  severity    String    @default("medium") // 'low', 'medium', 'high', 'critical'
  description String
  metadata    Json?
  status      String    @default("pending") // 'pending', 'reviewed', 'resolved', 'false_positive'
  notified_at DateTime?
  reviewed_by String?
  reviewed_at DateTime?
  created_at  DateTime  @default(now())
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([severity])
  @@index([created_at])
  @@map("suspicious_activity_alerts")
}

model LegalEntityInfo {
  id               String   @id @default(uuid())
  company_name     String
  legal_form       String?
  registration_number String?
  vat_number       String?
  address          String
  city             String
  postal_code      String?
  country          String
  phone            String?
  email            String
  dpo_name         String?
  dpo_email        String?
  dpo_phone        String?
  data_controller  String?
  hosting_provider String?
  hosting_region   String?
  updated_at       DateTime @updatedAt

  @@map("legal_entity_info")
}

model DataRetentionPolicy {
  id                   String    @id @default(uuid())
  data_type            String    @unique
  retention_days       Int
  description          String?
  auto_delete_enabled  Boolean   @default(true)
  last_cleanup_at      DateTime?
  updated_at           DateTime  @updatedAt

  @@map("data_retention_policies")
}

model ConsentLog {
  id              String   @id @default(uuid())
  user_id         String?
  consent_type    String
  consent_given   Boolean
  consent_version String?
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())

  @@index([user_id])
  @@index([consent_type])
  @@index([created_at])
  @@map("consent_logs")
}
