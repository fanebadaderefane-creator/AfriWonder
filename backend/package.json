{
  "name": "afriwonder-backend",
  "version": "1.0.0",
  "description": "Backend API pour AfriWonder - Express, Prisma, PostgreSQL (base de données propre, indépendant)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "test:db:prepare": "node scripts/migrate-test-db.js",
    "test": "npm run test:db:prepare && cross-env NODE_ENV=test NODE_OPTIONS=--max-old-space-size=4096 node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js",
    "test:watch": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --watch",
    "test:coverage": "npm run test:db:prepare && cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --coverage --runInBand",
    "setup:env": "node create-env.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test:setup": "node scripts/setup-test-db.js",
    "test:create-db": "node scripts/create-test-db.js",
    "test:db": "cross-env NODE_ENV=test node scripts/migrate-test-db.js",
    "test:db:resolve": "cross-env NODE_ENV=test node scripts/resolve-test-migration.js",
    "test:smoke": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --testPathPattern=smoke.critical-path --runInBand",
    "test:ads": "npm run test:db:prepare && cross-env NODE_ENV=test JWT_SECRET=test_secret_key_for_jest_tests_only JWT_REFRESH_SECRET=test_refresh_secret_key_for_jest_tests node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --testPathPattern=__tests__/ads --runInBand",
    "check:prod-env": "node scripts/check-prod-env.js",
    "load-test": "node scripts/load-test-node.js"
  },
  "dependencies": {
    "prisma": "^7.3.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "@sentry/react": "^10.38.0",
    "agora-token": "^2.0.5",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "stripe": "^17.4.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.5",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
